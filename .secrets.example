# Machine-local secrets template — copy to .secrets and fill in.
# .secrets is gitignored. Sourced by zsh/00-exports.zsh in interactive shells.
#
# Convention: prefer 1Password CLI (`op`) for secrets that don't need to live
# in process env. Static `export` is only justified when subprocesses must
# inherit the value at fork time (e.g., Claude MCP servers reading
# GITHUB_PERSONAL_ACCESS_TOKEN). Everything else goes through `op run`.
#
# ── Per-command injection with `op run` ──────────────────────────────────
#   alias npm-publish='op run --no-masking -- npm publish'
#
# Pair with .npmrc:
#   //registry.npmjs.org/:_authToken=op://Personal/npm/credential
#
# `op run` resolves op:// references at exec time and never writes them to disk.
# Wrapper function lives in zsh/80-functions.zsh as `op-run`.
#
# ── Eager env (only when subprocesses need inheritance) ──────────────────
# export GITHUB_PERSONAL_ACCESS_TOKEN=""   # Claude MCP. Falls back to `gh auth token`.
