#!/bin/sh
# Global pre-commit hook (referenced by core.hooksPath in ~/.gitconfig).
# Runs gitleaks on staged changes; falls back to a literal repo-local
# .git/hooks/pre-commit if present.
#
# Bypass for a single commit:
#   git commit --no-verify  (only when you really need to)
#
# NOTE: Do NOT use `git rev-parse --git-path hooks/pre-commit` to locate the
# repo-local hook - that path resolution respects core.hooksPath and returns
# THIS script's own path, causing infinite recursion.

set -e

# Repo-local pre-commit takes precedence if present. Use the literal git dir
# (NOT --git-path) so core.hooksPath isn't applied to the lookup.
git_dir="$(git rev-parse --git-dir 2>/dev/null)" || exit 0
repo_hook="$git_dir/hooks/pre-commit"
if [ -f "$repo_hook" ] && [ -x "$repo_hook" ]; then
  "$repo_hook" || exit $?
fi

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact -v --no-banner
fi
