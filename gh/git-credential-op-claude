#!/usr/bin/env bash
# gh/git-credential-op-claude — git credential helper: resolve a least-privilege
# GitHub PAT from 1Password for the AGENT's git-over-HTTPS operations.
#
# Wired ONLY into Claude Code's git environment: dot-claude/settings.json sets
# credential.https://github.com.helper = op-claude via GIT_CONFIG_*, so a Claude
# session pushes/fetches with a fine-grained, Contents:read+write PAT instead of
# your broad `gh` OAuth token (which carries the perpetual `repo` scope across
# every repo). Your own terminal git is untouched — it keeps the `gh` credential
# helper from ~/.gitconfig. This bounds the agent's git blast radius, the
# confused-deputy mitigation GitHub + 1Password both recommend for automation.
#
# Mirrors gh-mcp-auth-header: the PAT lives in the `claude-agent` vault and is
# resolved via the claude-agent SERVICE ACCOUNT (token read inline from the
# macOS login keychain), so this runs headless with no biometric. When the
# keychain item is absent, `op read` falls back to the desktop biometric session.
#
# git credential protocol: invoked as `git-credential-op-claude <action>` with
# the request on stdin. We answer only `get`; `store`/`erase` are no-ops (the
# secret lives in 1Password, not git's credential store).
#
# PREREQUISITE: a fine-grained PAT must exist at OP_REF below. Mint one
# (Contents: read+write, all repos, set an expiry) and store it:
#   op item create --category "API Credential" --title "Claude Git PAT" \
#     --vault claude-agent credential=<pat>
# Until then, git-over-HTTPS as the agent will fail (this helper warns on stderr).
set -euo pipefail

OP_REF="op://claude-agent/Claude Git PAT/credential"

[[ "${1:-}" == "get" ]] || exit 0

command -v op > /dev/null 2>&1 || exit 0

# Prefer the service-account token from the keychain; export it only into this
# process so `op read` resolves without biometric. Empty/missing → desktop auth.
sa_token="$(security find-generic-password -s op-claude-agent -w 2> /dev/null || true)"
[[ -n "${sa_token}" ]] && export OP_SERVICE_ACCOUNT_TOKEN="${sa_token}"
unset sa_token

if ! pat="$(op read "${OP_REF}" 2> /dev/null)" || [[ -z "${pat}" ]]; then
  printf 'git-credential-op-claude: could not resolve %s — mint a fine-grained PAT into the claude-agent vault\n' "${OP_REF}" >&2
  exit 0
fi

# GitHub authenticates by the PAT; the username is arbitrary for a PAT but must
# be the literal x-access-token if this is ever swapped for a GitHub App token.
printf 'username=x-access-token\n'
printf 'password=%s\n' "${pat}"
