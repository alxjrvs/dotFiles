#!/usr/bin/env bash
# gh-mcp-auth-header — emit the GitHub MCP Authorization header as JSON.
#
# Used as the `headersHelper` for the user-scope `github` HTTP MCP server
# (registered by install/60-claude.sh into ~/.claude.json). Claude Code runs
# this at MCP connection time and merges the JSON it prints to stdout into the
# request headers, so the bearer token is resolved on demand — never exported
# into the shell env (which would leak it into every Bash subprocess Claude Code
# spawns) and never written to disk.
#
# The token comes from 1Password, matching the rest of the GitHub stack: auth
# and signing already go through the 1Password agent (op-ssh-sign). OP_REF points
# at a secure note holding a GitHub PAT with repo/read:org scopes for the MCP
# server. `op read` resolves at connect time and will prompt to unlock if
# 1Password is locked.
#
# Contract: print a JSON object of headers to stdout. On any failure, print an
# empty object so the connection fails cleanly (no Authorization header) rather
# than sending a malformed `Bearer ` with an empty value.
set -euo pipefail

OP_REF="op://Personal/Claude Github PAT/notesPlain"

command -v op > /dev/null 2>&1 || {
  printf '{}\n'
  exit 0
}

token="$(op read "${OP_REF}" 2> /dev/null)" || {
  printf '{}\n'
  exit 0
}

[[ -n "${token}" ]] || {
  printf '{}\n'
  exit 0
}

# GitHub PATs are [A-Za-z0-9_]; no JSON escaping required.
printf '{"Authorization":"Bearer %s"}\n' "${token}"
