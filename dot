#!/usr/bin/env bash
# dot — thin dispatcher; the single dotfiles command on PATH.
#
# Resolves DOTFILES_DIR once, then execs the matching topic script, passing
# remaining args through.
set -euo pipefail

# ── Resolve DOTFILES_DIR: env → dir of this script's resolved target → ~/dotFiles.
# First candidate that is a directory containing a Brewfile wins.
__valid_repo() { [[ -n "$1" && -d "$1" && -f "$1/Brewfile" ]]; }

resolve_dir() {
  if __valid_repo "${DOTFILES_DIR:-}"; then
    printf '%s' "$DOTFILES_DIR"
    return 0
  fi
  local self target dir
  self="${BASH_SOURCE[0]}"
  target=$(readlink -f "$self" 2> /dev/null || printf '%s' "$self")
  dir=$(cd "$(dirname "$target")" && pwd)
  if __valid_repo "$dir"; then
    printf '%s' "$dir"
    return 0
  fi
  if __valid_repo "${HOME:-}/dotFiles"; then
    printf '%s' "${HOME}/dotFiles"
    return 0
  fi
  # shellcheck disable=SC2016  # $DOTFILES_DIR is a literal env-var name in the message
  printf 'dot: cannot resolve DOTFILES_DIR (set $DOTFILES_DIR)\n' >&2
  exit 1
}

DIR=$(resolve_dir)

[[ $# -ge 1 ]] || {
  printf 'usage: dot <sync|update|doctor|prune|render|git-data|prompt-render|statusline|subagent-statusline|hook> [args...]\n' >&2
  exit 2
}

cmd="$1"
shift

case "$cmd" in
  --version | -V | version) printf 'dot 0.1.0 (dotfiles)\n' ;;
  sync) exec "$DIR/sync" "$@" ;;
  update) exec "$DIR/sync" --upgrade "$@" ;;
  doctor) exec "$DIR/doctor" "$@" ;;
  # Direct exec (not sync --only=prune) so the script's own flags work:
  # `dot prune -n` dry-runs, `dot prune -y` deletes unattended.
  prune) exec "$DIR/install/95-prune.sh" "$@" ;;
  render) exec "$DIR/render" "$@" ;;
  git-data) exec "$DIR/prompt/git-data" "$@" ;;
  prompt-render) exec "$DIR/prompt/prompt-render" "$@" ;;
  statusline) exec "$DIR/share/claude-statusline/statusline.sh" "$@" ;;
  subagent-statusline) exec "$DIR/share/claude-statusline/subagent-statusline.sh" "$@" ;;
  hook)
    [[ $# -ge 1 ]] || {
      printf 'dot hook: requires an <event>\n' >&2
      exit 2
    }
    event="$1"
    shift
    # Timing wraps the hook: capture start, run, capture rc, append one bounded
    # JSON line to the timings log (opt-in via DOTFILES_HOOK_TIMING=1), exit rc.
    # Runs AFTER the hook decision so a hook's own deny/exit is never delayed.
    _hook_start_ms=""
    if [[ "${DOTFILES_HOOK_TIMING:-}" == "1" ]]; then
      if command -v gdate > /dev/null 2>&1; then
        _hook_start_ms=$(gdate +%s%3N)
      elif date +%s%3N > /dev/null 2>&1; then
        _hook_start_ms=$(date +%s%3N)
      fi
    fi

    _hook_rc=0
    "$DIR/hooks/$event" "$@" || _hook_rc=$?

    if [[ "${DOTFILES_HOOK_TIMING:-}" == "1" && -n "$_hook_start_ms" ]]; then
      _hook_end_ms=""
      if command -v gdate > /dev/null 2>&1; then
        _hook_end_ms=$(gdate +%s%3N)
      elif date +%s%3N > /dev/null 2>&1; then
        _hook_end_ms=$(date +%s%3N)
      fi
      if [[ -n "$_hook_end_ms" ]]; then
        _hook_elapsed=$((_hook_end_ms - _hook_start_ms))
        _hook_ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2> /dev/null || printf '')
        _hook_state_dir="${HOME}/.claude/state"
        _hook_log="${_hook_state_dir}/hook-timings.jsonl"
        mkdir -p "$_hook_state_dir" 2> /dev/null || true
        # Bound the log: keep the last 500 lines once it grows past ~1000.
        if [[ -f "$_hook_log" ]]; then
          _hook_lines=$(wc -l < "$_hook_log" 2> /dev/null | tr -d '[:space:]')
          if [[ -n "$_hook_lines" && "$_hook_lines" -gt 1000 ]]; then
            tail -n 500 "$_hook_log" > "${_hook_log}.tmp" 2> /dev/null &&
              mv "${_hook_log}.tmp" "$_hook_log" 2> /dev/null || true
          fi
        fi
        printf '{"ts":"%s","event":"%s","elapsed_ms":%d,"rc":%d}\n' \
          "$_hook_ts" "$event" "$_hook_elapsed" "$_hook_rc" \
          >> "$_hook_log" 2> /dev/null || true
      fi
    fi

    exit "$_hook_rc"
    ;;
  *)
    printf 'dot: unknown subcommand: %s\n' "$cmd" >&2
    exit 2
    ;;
esac
