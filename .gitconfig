[alias]
  # Pretty log output
  hist = log --graph --pretty=format:'%Cred%h%Creset %s%C(yellow)%d%Creset %Cgreen(%cr)%Creset [%an]' --abbrev-commit --date=relative
  sw = switch
  st = status -sb
  undo = reset HEAD~1 --mixed

[user]
	name = alxjrvs
	email = alxjrvs@gmail.com
	# user.signingkey is machine-local (~/.gitconfig.local, written by
	# `dot sync` -> install/45-ssh.sh) -- a `key::` pubkey for the 1Password
	# "GitHubSSH" key. git signs via op-ssh-sign (1Password), no local key.
[credential]
	helper = osxkeychain
# GitHub HTTPS auth via the gh CLI (keychain-backed). Lets git push resolve a
# token on demand instead of needing a PAT in the environment. The empty
# `helper =` resets the inherited osxkeychain helper for github.com so gh is
# used. Mirrors `gh auth setup-git`.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[core]
	editor = nvim
	excludesfile = ~/.gitignore
	pager = delta
	fsmonitor = false
	untrackedCache = true

# New repos copy template/hooks/pre-commit into their own .git/hooks/ at
# `git init`/`git clone` time → gitleaks runs per-repo without conflicting
# with lefthook (which owns .git/hooks/pre-commit in lefthook-equipped repos).
# Repos that predate the template need a one-shot:
#   cp ~/.config/git/template/hooks/pre-commit <repo>/.git/hooks/pre-commit
[init]
	defaultBranch = main
	templateDir = ~/.config/git/template
[commit]
	template = ~/.gitmessage
	verbose = true
	# Anything below the scissors line in the commit message is stripped.
	cleanup = scissors
	# gpgSign lives in ~/.gitconfig.local (machine-local) so fresh boxes don't
	# fail commits before SSH keys are set up. See `dot sync` bootstrap step.
[push]
	autoSetupRemote = true
	followTags = true
[pull]
	rebase = true
[rerere]
	enabled = true
	autoupdate = true
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	dark = true
	hyperlinks = true
[fetch]
	prune = true
	pruneTags = true
	writeCommitGraph = true
[merge]
	conflictstyle = zdiff3
[branch]
	sort = -committerdate
[column]
	ui = auto
[diff]
	algorithm = histogram
	colorMoved = dimmed-zebra
	mnemonicPrefix = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[tag]
	sort = version:refname
	# gpgSign lives in ~/.gitconfig.local
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[help]
	autocorrect = prompt
[include]
	path = ~/.gitconfig.local
