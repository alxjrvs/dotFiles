#!/usr/bin/env bash
# render — resolve {{ op "op://..." }} placeholders in a template file.
#
# Usage: render <template-file>
#   Writes resolved content to stdout. Redirect to a destination file if needed.
#
# Fails loudly on the FIRST missing ref — never produces partially-rendered
# output. Each unique placeholder is resolved once even if it appears multiple
# times (deduped via an associative array keyed on the full placeholder string).
#
# Whitespace-tolerant: {{ op "op://..." }} / {{op "op://..."}} /
# {{   op  "op://..."   }} all match.
set -euo pipefail

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------
if [[ $# -ne 1 ]]; then
  printf 'usage: render <template-file>\n' >&2
  exit 1
fi

template_file="$1"

if [[ ! -f "$template_file" ]]; then
  printf 'render: template not found: %s\n' "$template_file" >&2
  exit 1
fi

# Read file preserving trailing newlines (unlike $(<file) which strips them).
{ IFS= read -r -d '' template || true; } < "$template_file"

# ---------------------------------------------------------------------------
# Phase 1: collect all unique placeholders, resolve each op:// ref once.
#
# resolved[placeholder] = value  (keyed on the full {{ ... }} match string,
# mirroring the Rust dedup which also keys on the full match).
# ---------------------------------------------------------------------------
declare -A resolved=()

while IFS= read -r placeholder; do
  [[ -z "$placeholder" ]] && continue
  # Already resolved this exact placeholder string — skip.
  [[ -v resolved["$placeholder"] ]] && continue

  # Extract the op:// reference from between the double-quotes.
  ref="$(printf '%s' "$placeholder" | grep -oE 'op://[^"]+')"

  # Resolve via 1Password CLI.  Capture stderr for the error message.
  # Fail loudly on first miss — no partial output ever reaches stdout.
  if ! raw="$(op read "$ref" 2>&1)"; then
    printf 'render: op read %s failed: %s\n' "$ref" "$raw" >&2
    exit 1
  fi

  # op read appends a trailing newline; strip it — the template expects the
  # bare value (same as Rust: trim_end_matches('\n')).
  value="${raw%$'\n'}"

  resolved["$placeholder"]="$value"
done < <(
  # Extract every {{ op "op://..." }} token, one per line, deduped.
  # The regex mirrors Rust: \{\{\s*op\s+"(op://[^"]+)"\s*\}\}
  printf '%s' "$template" |
    grep -oE '\{\{[[:space:]]*op[[:space:]]+"op://[^"]+"[[:space:]]*\}\}' |
    sort -u ||
    true
)

# No placeholders found — pass template through unchanged.
if [[ ${#resolved[@]} -eq 0 ]]; then
  printf '%s' "$template"
  exit 0
fi

# ---------------------------------------------------------------------------
# Phase 2: substitute all placeholders in the template.
#
# Bash ${var//"$ph"/"$val"} performs literal string replacement (the pattern
# is double-quoted, preventing glob expansion).  The only glob-special chars
# in bash patterns are * ? [ \ — none appear in valid {{ op "op://..." }}
# placeholders, so this is safe for all expected inputs.
# ---------------------------------------------------------------------------
result="$template"
for placeholder in "${!resolved[@]}"; do
  value="${resolved[$placeholder]}"
  result="${result//"$placeholder"/"$value"}"
done

printf '%s' "$result"
