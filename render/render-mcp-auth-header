#!/usr/bin/env bash
# render-mcp-auth-header — emit the Render MCP Authorization header as JSON.
#
# Used as the `headersHelper` for the project-local `render` HTTP MCP server in
# the SU-SRD repo (registered into ~/.claude.json under that project's scope).
# Claude Code runs this at MCP connection time and merges the JSON it prints to
# stdout into the request headers, so the API key is resolved on demand — never
# exported into the shell env (which would leak it into every Bash subprocess
# Claude Code spawns) and never written to disk.
#
# Mirrors gh-mcp-auth-header: the secret comes from 1Password. OP_REF points at
# the "Render API Key" item's credential field. `op read` resolves at connect
# time and will prompt to unlock if 1Password is locked.
#
# Contract: print a JSON object of headers to stdout. On any failure, print an
# empty object so the connection fails cleanly (no Authorization header) rather
# than sending a malformed `Bearer ` with an empty value.
set -euo pipefail

OP_REF="op://Private/Render API Key/credential"

command -v op > /dev/null 2>&1 || {
  printf '{}\n'
  exit 0
}

token="$(op read "${OP_REF}" 2> /dev/null)" || {
  printf '{}\n'
  exit 0
}

[[ -n "${token}" ]] || {
  printf '{}\n'
  exit 0
}

# Render API keys are [A-Za-z0-9_-]; no JSON escaping required.
printf '{"Authorization":"Bearer %s"}\n' "${token}"
