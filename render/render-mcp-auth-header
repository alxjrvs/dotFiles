#!/usr/bin/env bash
# render-mcp-auth-header — emit the Render MCP Authorization header as JSON.
#
# Used as the `headersHelper` for the project-local `render` HTTP MCP server in
# the SU-SRD repo (registered into ~/.claude.json under that project's scope).
# Claude Code runs this at MCP connection time and merges the JSON it prints to
# stdout into the request headers, so the API key is resolved on demand — never
# exported into the shell env (which would leak it into every Bash subprocess
# Claude Code spawns) and never written to disk.
#
# Mirrors gh-mcp-auth-header: resolution prefers the `claude-agent` service
# account (install/47-op-agent.sh). Its token lives in the macOS login keychain,
# is read INLINE here, and reaches `op read` only within this short-lived
# process — so neither it nor the API key touches a Bash subprocess, the
# transcript, or OTEL spans. No Touch ID prompt, no desktop-app dependency
# (headless-safe); when the keychain item is absent it falls back to desktop
# biometric. OP_REF points at the Render API key in the claude-agent vault —
# service accounts can't read Personal/Private.
#
# Contract: print a JSON object of headers to stdout. On any failure, print an
# empty object so the connection fails cleanly (no Authorization header) rather
# than sending a malformed `Bearer ` with an empty value.
set -euo pipefail

OP_REF="op://claude-agent/Render API Key/credential"

command -v op > /dev/null 2>&1 || {
  printf '{}\n'
  exit 0
}

# Prefer the service-account token from the keychain; export it only into this
# process so `op read` resolves without biometric. Empty/missing → desktop auth.
sa_token="$(security find-generic-password -s op-claude-agent -w 2> /dev/null || true)"
[[ -n "${sa_token}" ]] && export OP_SERVICE_ACCOUNT_TOKEN="${sa_token}"
unset sa_token

token="$(op read "${OP_REF}" 2> /dev/null)" || {
  printf '{}\n'
  exit 0
}

[[ -n "${token}" ]] || {
  printf '{}\n'
  exit 0
}

# Render API keys are [A-Za-z0-9_-]; no JSON escaping required.
printf '{"Authorization":"Bearer %s"}\n' "${token}"
