#!/usr/bin/env bash
# hooks/session-start — SessionStart: set the session banner title.
#
# Reads .cwd from CC JSON (fallback to $PWD). Then:
#   - In a git repo with a branch: "<repo-basename>:<branch>"
#   - In a git repo, detached HEAD:  "<repo-basename>"
#   - Outside a repo:               "<cwd-basename>"
#
# Emits hookSpecificOutput.sessionTitle if non-empty. Silent on empty.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -euo pipefail

# ---------------------------------------------------------------------------
# Timing instrumentation
# ---------------------------------------------------------------------------
_HOOK_START_MS=0
if [[ "${DOTFILES_HOOK_TIMING:-}" == "1" ]]; then
  if command -v gdate > /dev/null 2>&1; then
    _HOOK_START_MS=$(gdate +%s%3N)
  elif date +%s%3N > /dev/null 2>&1; then
    _HOOK_START_MS=$(date +%s%3N)
  fi
fi

_log_timing() {
  local ok="$1"
  if [[ "${DOTFILES_HOOK_TIMING:-}" != "1" ]]; then
    return 0
  fi
  local end_ms=0
  if command -v gdate > /dev/null 2>&1; then
    end_ms=$(gdate +%s%3N)
  elif date +%s%3N > /dev/null 2>&1; then
    end_ms=$(date +%s%3N)
  fi
  local elapsed=$((end_ms - _HOOK_START_MS))
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2> /dev/null || echo "")
  local state_dir="${HOME}/.claude/state"
  mkdir -p "$state_dir"
  printf '{"ts":"%s","event":"session-start","elapsed_ms":%d,"ok":%s}\n' \
    "$ts" "$elapsed" "$ok" \
    >> "${state_dir}/hook-timings.jsonl"
}

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

CWD=$(printf '%s' "$INPUT" | jq -r '.cwd // ""')
if [[ -z "$CWD" ]]; then
  CWD="$PWD"
fi

# ---------------------------------------------------------------------------
# Derive title
# ---------------------------------------------------------------------------
# Try to get git toplevel (run in the session's cwd)
TOPLEVEL=""
if TOPLEVEL=$(git -C "$CWD" rev-parse --show-toplevel 2> /dev/null) && [[ -n "$TOPLEVEL" ]]; then
  REPO_BASENAME=$(basename "$TOPLEVEL")

  # Try to get the current branch (symbolic-ref fails on detached HEAD)
  BRANCH=""
  if BRANCH=$(git -C "$CWD" symbolic-ref --short -q HEAD 2> /dev/null) && [[ -n "$BRANCH" ]]; then
    TITLE="${REPO_BASENAME}:${BRANCH}"
  else
    # Detached HEAD -> repo name only
    TITLE="${REPO_BASENAME}"
  fi
else
  # Not a git repo -> cwd basename
  TITLE=$(basename "$CWD")
fi

if [[ -z "$TITLE" ]]; then
  _log_timing "true"
  exit 0
fi

# ---------------------------------------------------------------------------
# Emit sessionTitle
# ---------------------------------------------------------------------------
jq -n \
  --arg title "$TITLE" \
  '{hookSpecificOutput:{hookEventName:"SessionStart",sessionTitle:$title}}'

_log_timing "true"
exit 0
