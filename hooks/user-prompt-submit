#!/usr/bin/env bash
# hooks/user-prompt-submit — UserPromptSubmit: inject git status context.
#
# 1. Finds repo root (git rev-parse --show-toplevel, fallback to $PWD).
# 2. If the git-data cache is >60s stale or missing, spawns `dot git-data &`
#    detached so the next turn sees fresh data.
# 3. Loads the cache. Silent if GIT_IS_REPO != 1.
# 4. Suppresses output on a clean default branch (main/master/develop/trunk)
#    with no uncommitted/ahead/behind/conflict/PR state.
# 5. Otherwise emits one additionalContext line:
#    git: branch=<name>[, N uncommitted][, N ahead][, N behind][, N CONFLICTS][, PR-checks=<status>]
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Inline: cache path resolution
#
#   hash = 12 hex chars of FNV-1a over the toplevel path (low 48 bits)
#   dir  = ${XDG_CACHE_HOME:-~/.cache}/git-data
#   file = <dir>/<hash>.sh
#
# repo_hash is IDENTICAL to the function in prompt/git-data and
# prompt/prompt-render (bats asserts it) so all consumers agree.
# ---------------------------------------------------------------------------
repo_hash() {
  local path="$1" out="${2:-}"
  local -i h=-3750763034362895579 prime=1099511628211 c # 0xcbf29ce484222325
  local i
  for ((i = 0; i < ${#path}; i++)); do
    printf -v c '%d' "'${path:i:1}"
    ((h ^= c, h *= prime)) || true
  done
  if [[ -n "$out" ]]; then
    printf -v "$out" '%012x' $((h & 0xFFFFFFFFFFFF))
  else
    printf '%012x' $((h & 0xFFFFFFFFFFFF))
  fi
}

git_cache_path() {
  local toplevel="${1:-}"
  local key
  if [[ -z "$toplevel" ]]; then
    key="$PWD"
  else
    key="$toplevel"
  fi
  local hash
  repo_hash "$key" hash
  printf '%s/git-data/%s.sh' "${XDG_CACHE_HOME:-${HOME}/.cache}" "$hash"
}

# ---------------------------------------------------------------------------
# Resolve repo root
# ---------------------------------------------------------------------------
TOPLEVEL=""
if TOPLEVEL=$(git rev-parse --show-toplevel 2> /dev/null) && [[ -n "$TOPLEVEL" ]]; then
  : # already set
else
  TOPLEVEL="$PWD"
fi

# ---------------------------------------------------------------------------
# Check cache staleness (>60s or missing -> background refresh)
# ---------------------------------------------------------------------------
CACHE_PATH=$(git_cache_path "$TOPLEVEL" 2> /dev/null || true)

if [[ -n "$CACHE_PATH" ]]; then
  _is_stale=1
  if [[ -f "$CACHE_PATH" ]]; then
    # Get mtime: macOS stat -f%m, GNU stat -c%Y
    if MTIME=$(stat -f%m "$CACHE_PATH" 2> /dev/null); then
      : # macOS
    elif MTIME=$(stat -c%Y "$CACHE_PATH" 2> /dev/null); then
      : # Linux
    else
      MTIME=0
    fi
    NOW=$(date +%s)
    AGE=$((NOW - MTIME))
    if [[ "$AGE" -le 60 ]]; then
      _is_stale=0
    fi
  fi

  if [[ "$_is_stale" == "1" ]]; then
    # Resolve dot command: try relative to this script, then PATH
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    DOT_CMD="$SCRIPT_DIR/../dot"
    if [[ ! -x "$DOT_CMD" ]]; then
      if command -v dot > /dev/null 2>&1; then
        DOT_CMD="dot"
      else
        DOT_CMD=""
      fi
    fi
    if [[ -n "$DOT_CMD" ]]; then
      # Bound the detached refresh so a wedged git-data can't linger. Stock
      # macOS has no `timeout`; coreutils ships it as `gtimeout`.
      if command -v timeout > /dev/null 2>&1; then
        timeout 10 "$DOT_CMD" git-data < /dev/null > /dev/null 2>&1 &
      elif command -v gtimeout > /dev/null 2>&1; then
        gtimeout 10 "$DOT_CMD" git-data < /dev/null > /dev/null 2>&1 &
      else
        "$DOT_CMD" git-data < /dev/null > /dev/null 2>&1 &
      fi
      disown 2> /dev/null || true
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Load cache variables
# ---------------------------------------------------------------------------
# Define GIT_* defaults before sourcing so they are always set
GIT_IS_REPO=0
GIT_BRANCH=""
GIT_STAGED_COUNT=0
GIT_UNSTAGED_COUNT=0
GIT_UNTRACKED_COUNT=0
GIT_AHEAD=0
GIT_BEHIND=0
GIT_CONFLICT_COUNT=0
GIT_PR_STATUS=""

if [[ -n "$CACHE_PATH" ]] && [[ -f "$CACHE_PATH" ]]; then
  # Safe ingest: NEVER `source` or `eval` the cache. It lives at a predictable
  # <sha>.sh path under ~/.cache — which is sandbox-writable, so a (possibly
  # prompt-injected) sandboxed command can pre-seed it, and this hook runs
  # UNSANDBOXED. `grep | eval` is NOT safe: a seeded line like `GIT_X=1; cmd`
  # passes the `^GIT_…=` filter and eval would execute `cmd`. Instead, accept
  # ONLY the exact single-quoted shape git-data emits (GIT_NAME='value') via a
  # fully-anchored regex, and assign with `printf -v` (which never evaluates).
  # Command substitutions, backticks, semicolons, and embedded quotes can't
  # appear in a matching value, so none can execute. Values containing a single
  # quote (esc()'d to '\'' by git-data) won't match and are skipped — safe to
  # drop, as consumers only display branch/counts/PR status.
  while IFS= read -r _l; do
    [[ $_l =~ ^(GIT_[A-Z_]+)=\'([^\']*)\'$ ]] || continue
    printf -v "${BASH_REMATCH[1]}" '%s' "${BASH_REMATCH[2]}"
  done < "$CACHE_PATH"
fi

# ---------------------------------------------------------------------------
# Guard: not a repo
# ---------------------------------------------------------------------------
if [[ "${GIT_IS_REPO:-0}" != "1" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Compute aggregates
# ---------------------------------------------------------------------------
UNCOMMITTED=$((${GIT_STAGED_COUNT:-0} + ${GIT_UNSTAGED_COUNT:-0} + ${GIT_UNTRACKED_COUNT:-0}))
AHEAD=${GIT_AHEAD:-0}
BEHIND=${GIT_BEHIND:-0}
CONFLICTS=${GIT_CONFLICT_COUNT:-0}
PR_STATUS="${GIT_PR_STATUS:-}"
PR_DISPLAY="${PR_STATUS:-none}"
BRANCH="${GIT_BRANCH:-}"

# ---------------------------------------------------------------------------
# Suppress on clean default branch
# ---------------------------------------------------------------------------
IS_DEFAULT=0
case "$BRANCH" in
  main | master | develop | trunk) IS_DEFAULT=1 ;;
esac

if [[ "$IS_DEFAULT" == "1" ]] &&
  [[ "$UNCOMMITTED" -eq 0 ]] &&
  [[ "$AHEAD" -eq 0 ]] &&
  [[ "$BEHIND" -eq 0 ]] &&
  [[ "$CONFLICTS" -eq 0 ]] &&
  [[ "$PR_DISPLAY" == "none" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Build summary line
# ---------------------------------------------------------------------------
PARTS="branch=${BRANCH}"
[[ "$UNCOMMITTED" -gt 0 ]] && PARTS="${PARTS}, ${UNCOMMITTED} uncommitted"
[[ "$AHEAD" -gt 0 ]] && PARTS="${PARTS}, ${AHEAD} ahead"
[[ "$BEHIND" -gt 0 ]] && PARTS="${PARTS}, ${BEHIND} behind"
[[ "$CONFLICTS" -gt 0 ]] && PARTS="${PARTS}, ${CONFLICTS} CONFLICTS"
[[ "$PR_DISPLAY" != "none" ]] && PARTS="${PARTS}, PR-checks=${PR_DISPLAY}"

# Emit as additionalContext via jq for safe JSON encoding. additionalContext
# is only documented inside the hookSpecificOutput envelope.
jq -n --arg line "git: ${PARTS}" \
  '{hookSpecificOutput:{hookEventName:"UserPromptSubmit",additionalContext:$line}}'

exit 0
