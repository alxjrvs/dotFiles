#!/usr/bin/env bash
# hooks/user-prompt-submit — UserPromptSubmit: inject git status context.
#
# 1. Finds repo root (git rev-parse --show-toplevel, fallback to $PWD).
# 2. If the git-data cache is >60s stale or missing, spawns `dot git-data &`
#    detached so the next turn sees fresh data.
# 3. Loads the cache. Silent if GIT_IS_REPO != 1.
# 4. Suppresses output on a clean default branch (main/master/develop/trunk)
#    with no uncommitted/ahead/behind/conflict/PR state.
# 5. Otherwise emits one additionalContext line:
#    git: branch=<name>[, N uncommitted][, N ahead][, N behind][, N CONFLICTS][, PR-checks=<status>]
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Inline: git_cache_path <toplevel>
#
# Mirrors cache_path() in git_data.rs:
#   hash = SHA-256 of toplevel path, first 12 hex chars
#   dir  = ${XDG_CACHE_HOME:-~/.cache}/git-data
#   file = <dir>/<hash>.sh
#
# Uses `shasum -a 256` (macOS) or `sha256sum` (Linux). The shell prompt and
# statusline use the same function so all consumers stay consistent.
# ---------------------------------------------------------------------------
git_cache_path() {
  local toplevel="${1:-}"
  local key
  if [[ -z "$toplevel" ]]; then
    key="$PWD"
  else
    key="$toplevel"
  fi

  local hash
  if command -v shasum > /dev/null 2>&1; then
    hash=$(printf '%s' "$key" | shasum -a 256 | cut -c1-12)
  elif command -v sha256sum > /dev/null 2>&1; then
    hash=$(printf '%s' "$key" | sha256sum | cut -c1-12)
  else
    # Fallback: use md5 (less ideal but avoids hard failure)
    hash=$(printf '%s' "$key" | md5sum 2> /dev/null | cut -c1-12 ||
      printf '%s' "$key" | md5 | cut -c1-12)
  fi

  local cache_dir
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/git-data"
  printf '%s/%s.sh' "$cache_dir" "$hash"
}

# ---------------------------------------------------------------------------
# Resolve repo root
# ---------------------------------------------------------------------------
TOPLEVEL=""
if TOPLEVEL=$(git rev-parse --show-toplevel 2> /dev/null) && [[ -n "$TOPLEVEL" ]]; then
  : # already set
else
  TOPLEVEL="$PWD"
fi

# ---------------------------------------------------------------------------
# Check cache staleness (>60s or missing -> background refresh)
# ---------------------------------------------------------------------------
CACHE_PATH=$(git_cache_path "$TOPLEVEL" 2> /dev/null || true)

if [[ -n "$CACHE_PATH" ]]; then
  _is_stale=1
  if [[ -f "$CACHE_PATH" ]]; then
    # Get mtime: macOS stat -f%m, GNU stat -c%Y
    if MTIME=$(stat -f%m "$CACHE_PATH" 2> /dev/null); then
      : # macOS
    elif MTIME=$(stat -c%Y "$CACHE_PATH" 2> /dev/null); then
      : # Linux
    else
      MTIME=0
    fi
    NOW=$(date +%s)
    AGE=$((NOW - MTIME))
    if [[ "$AGE" -le 60 ]]; then
      _is_stale=0
    fi
  fi

  if [[ "$_is_stale" == "1" ]]; then
    # Resolve dot command: try relative to this script, then PATH
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    DOT_CMD="$SCRIPT_DIR/../dot"
    if [[ ! -x "$DOT_CMD" ]]; then
      if command -v dot > /dev/null 2>&1; then
        DOT_CMD="dot"
      else
        DOT_CMD=""
      fi
    fi
    if [[ -n "$DOT_CMD" ]]; then
      # Bound the detached refresh so a wedged git-data can't linger.
      if command -v timeout > /dev/null 2>&1; then
        timeout 10 "$DOT_CMD" git-data < /dev/null > /dev/null 2>&1 &
      else
        "$DOT_CMD" git-data < /dev/null > /dev/null 2>&1 &
      fi
      disown 2> /dev/null || true
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Load cache variables
# ---------------------------------------------------------------------------
# Define GIT_* defaults before sourcing so they are always set
GIT_IS_REPO=0
GIT_BRANCH=""
GIT_STAGED_COUNT=0
GIT_UNSTAGED_COUNT=0
GIT_UNTRACKED_COUNT=0
GIT_AHEAD=0
GIT_BEHIND=0
GIT_CONFLICT_COUNT=0
GIT_PR_STATUS=""

if [[ -n "$CACHE_PATH" ]] && [[ -f "$CACHE_PATH" ]]; then
  # Safe ingest: never `source` the cache (it lives at a predictable
  # <sha>.sh path an attacker could pre-seed — sourcing is arbitrary code
  # exec). Read only well-formed GIT_* assignment lines and eval those.
  while IFS= read -r _l; do
    eval "$_l"
  done < <(grep -E '^GIT_[A-Z_]+=' "$CACHE_PATH" 2> /dev/null)
fi

# ---------------------------------------------------------------------------
# Guard: not a repo
# ---------------------------------------------------------------------------
if [[ "${GIT_IS_REPO:-0}" != "1" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Compute aggregates
# ---------------------------------------------------------------------------
UNCOMMITTED=$((${GIT_STAGED_COUNT:-0} + ${GIT_UNSTAGED_COUNT:-0} + ${GIT_UNTRACKED_COUNT:-0}))
AHEAD=${GIT_AHEAD:-0}
BEHIND=${GIT_BEHIND:-0}
CONFLICTS=${GIT_CONFLICT_COUNT:-0}
PR_STATUS="${GIT_PR_STATUS:-}"
PR_DISPLAY="${PR_STATUS:-none}"
[[ -z "$PR_STATUS" ]] && PR_DISPLAY="none"
BRANCH="${GIT_BRANCH:-}"

# ---------------------------------------------------------------------------
# Suppress on clean default branch
# ---------------------------------------------------------------------------
IS_DEFAULT=0
case "$BRANCH" in
  main | master | develop | trunk) IS_DEFAULT=1 ;;
esac

if [[ "$IS_DEFAULT" == "1" ]] &&
  [[ "$UNCOMMITTED" -eq 0 ]] &&
  [[ "$AHEAD" -eq 0 ]] &&
  [[ "$BEHIND" -eq 0 ]] &&
  [[ "$CONFLICTS" -eq 0 ]] &&
  [[ "$PR_DISPLAY" == "none" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Build summary line
# ---------------------------------------------------------------------------
PARTS="branch=${BRANCH}"
[[ "$UNCOMMITTED" -gt 0 ]] && PARTS="${PARTS}, ${UNCOMMITTED} uncommitted"
[[ "$AHEAD" -gt 0 ]] && PARTS="${PARTS}, ${AHEAD} ahead"
[[ "$BEHIND" -gt 0 ]] && PARTS="${PARTS}, ${BEHIND} behind"
[[ "$CONFLICTS" -gt 0 ]] && PARTS="${PARTS}, ${CONFLICTS} CONFLICTS"
[[ "$PR_DISPLAY" != "none" ]] && PARTS="${PARTS}, PR-checks=${PR_DISPLAY}"

# Emit as additionalContext via jq for safe JSON encoding
jq -n --arg line "git: ${PARTS}" '{"additionalContext": $line}'

exit 0
