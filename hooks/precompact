#!/usr/bin/env bash
# hooks/precompact — PreCompact: append a plan-snapshot line before compaction.
#
# Reads session_id, transcript_path, trigger, cwd from CC JSON on stdin.
# Appends {ts, trigger, session_id, transcript_path, cwd} to
# ~/.claude/state/precompact-snapshots.jsonl.
# Always exits 0 — never blocks compaction. Best-effort logger.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# jq is required to parse the payload; if absent, silently no-op (logger, not defender).
command -v jq > /dev/null 2>&1 || exit 0

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2> /dev/null || echo "")
TRIGGER=$(printf '%s' "$INPUT" | jq -r '.trigger // empty')
SESSION_ID=$(printf '%s' "$INPUT" | jq -r '.session_id // empty')
TRANSCRIPT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty')
CWD_VAL=$(printf '%s' "$INPUT" | jq -r '.cwd // empty')

# ---------------------------------------------------------------------------
# Append JSONL snapshot
# ---------------------------------------------------------------------------
STATE_DIR="${HOME}/.claude/state"
mkdir -p "$STATE_DIR"

LEDGER="${STATE_DIR}/precompact-snapshots.jsonl"
# Secrets-at-rest: lock the ledger to the owner on first creation.
if [[ ! -e "$LEDGER" ]]; then
  : >> "$LEDGER"
  chmod 600 "$LEDGER" 2> /dev/null || true
fi

jq -cn \
  --arg ts "$TS" \
  --arg trigger "$TRIGGER" \
  --arg session_id "$SESSION_ID" \
  --arg transcript_path "$TRANSCRIPT" \
  --arg cwd "$CWD_VAL" \
  '{ts:$ts,trigger:$trigger,session_id:$session_id,transcript_path:$transcript_path,cwd:$cwd}' \
  >> "$LEDGER" 2> /dev/null || true

# ---------------------------------------------------------------------------
# Self-bound: trim to last 500 lines once the file exceeds 1000.
# ---------------------------------------------------------------------------
LINES=$(wc -l < "$LEDGER" 2> /dev/null | tr -d ' ')
if [[ -n "$LINES" && "$LINES" -gt 1000 ]]; then
  TMP="${LEDGER}.tmp.$$"
  if tail -n 500 "$LEDGER" > "$TMP" 2> /dev/null; then
    chmod 600 "$TMP" 2> /dev/null || true
    mv "$TMP" "$LEDGER" 2> /dev/null || rm -f "$TMP" 2> /dev/null || true
  else
    rm -f "$TMP" 2> /dev/null || true
  fi
fi

exit 0
