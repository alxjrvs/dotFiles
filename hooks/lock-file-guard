#!/usr/bin/env bash
# hooks/lock-file-guard — PreToolUse: deny edits to dependency lock files
# and secret-bearing dotenv files.
#
# Reads .tool_input.file_path (or .file_path) from CC JSON on stdin.
# Emits a deny JSON payload + exits 0 when the basename matches the
# known lock-file list or is a .env/.env.* file (templates exempt).
# Silent (exit 0, no output) otherwise.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
#
# Defender: -e is intentionally OFF so a failed command-substitution can never
# abort the guard before it emits its deny (which CC would treat as allow).
set -uo pipefail

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

# Robust fail-closed deny. Normal path: emit a clean permissionDecision:deny
# JSON on stdout and exit 0. If jq itself fails to emit (present-but-broken jq,
# locale/OOM), DON'T fall through to a silent exit 0 (which CC treats as ALLOW)
# — write the reason to stderr and `exit 2`, which hard-blocks the tool and
# shows the reason. Belt-and-suspenders against the deny-emitter failing.
emit_deny() {
  local reason="$1"
  if jq -n --arg reason "$reason" \
    '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}'; then
    exit 0
  fi
  printf '%s\n' "$reason" >&2
  exit 2
}

# Fail closed: this hook's whole job is to deny. If jq is unavailable we cannot
# inspect the payload, so deny rather than silently pass. (printf is a builtin,
# so this branch needs no jq.)
if ! command -v jq > /dev/null 2>&1; then
  printf '%s\n' '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"lock-file-guard: jq unavailable, denying to fail closed"}}'
  exit 0
fi

# Extract file_path: try .tool_input.file_path first, fall back to .file_path
FILE_PATH=$(printf '%s' "$INPUT" | jq -r '(.tool_input.file_path // .file_path) // ""')

if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

BASENAME=$(basename "$FILE_PATH")
# Lowercase copy for matching: macOS default APFS is case-insensitive, so
# Bun.Lock / CARGO.LOCK / .ENV resolve to the same real file and must match.
# Use tr (not ${BASENAME,,}) to stay bash-3.2 compatible like the other hooks.
BASENAME_LC=$(printf '%s' "$BASENAME" | tr '[:upper:]' '[:lower:]')

# ---------------------------------------------------------------------------
# Lock file list (mirrors LOCKS in hook.rs). Stored lowercase so the
# case-insensitive comparison against BASENAME_LC needs no per-iteration tr.
# ---------------------------------------------------------------------------
LOCK_FILES=(
  "brewfile.lock"
  "brewfile.lock.json"
  "bun.lock"
  "bun.lockb"
  "package-lock.json"
  "yarn.lock"
  "pnpm-lock.yaml"
  "gemfile.lock"
  "cargo.lock"
  "composer.lock"
  "poetry.lock"
  "uv.lock"
  "flake.lock"
)

for lock in "${LOCK_FILES[@]}"; do
  if [[ "$BASENAME_LC" == "$lock" ]]; then
    REASON="Do not edit lock files directly — ${BASENAME} is dependency-managed. Run the package manager (bun/cargo/brew) to regenerate it."
    emit_deny "$REASON"
  fi
done

# ---------------------------------------------------------------------------
# Dotenv files (secrets policy: never write plaintext tokens to .env files).
# Templates are exempt — they hold placeholders, not secrets.
# ---------------------------------------------------------------------------
case "$BASENAME_LC" in
  .env.example | .env.template | .env.sample) ;;
  .env | .env.*)
    REASON="Do not write to ${BASENAME} — secrets live in 1Password. Use an op:// reference + op-run, or direnv + 'op read' in .envrc (see CLAUDE.md secrets policy). Templates (.env.example) are allowed."
    emit_deny "$REASON"
    ;;
esac

exit 0
