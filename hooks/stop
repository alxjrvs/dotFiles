#!/usr/bin/env bash
# hooks/stop — Stop: append session JSONL record.
#
# Reads session_id, cwd, transcript_path from CC JSON on stdin.
# Appends {ts, session_id, cwd, transcript_path} to a PER-SESSION shard:
# ~/.claude/state/sessions/<session_id>.jsonl. Per-session sharding avoids
# cross-session line interleaving/corruption that a single append-only file
# risks when records exceed PIPE_BUF and concurrent sessions write at once.
# Always exits 0 — failures are best-effort (don't break session teardown).
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2> /dev/null || echo "")
SESSION_ID=$(printf '%s' "$INPUT" | jq -r '.session_id // ""')
CWD_VAL=$(printf '%s' "$INPUT" | jq -r '.cwd // ""')
TRANSCRIPT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // ""')

# ---------------------------------------------------------------------------
# Append JSONL record to a per-session shard
# ---------------------------------------------------------------------------
SESSIONS_DIR="${HOME}/.claude/state/sessions"
mkdir -p "$SESSIONS_DIR"

# Derive the shard name from .session_id; fall back to the transcript basename
# (sans extension), then a safe single 'unknown' shard. Sanitize to keep the
# filename to a known-safe charset.
SHARD_ID="$SESSION_ID"
if [[ -z "$SHARD_ID" && -n "$TRANSCRIPT" ]]; then
  SHARD_ID=$(basename "$TRANSCRIPT")
  SHARD_ID="${SHARD_ID%.*}"
fi
SHARD_ID=$(printf '%s' "$SHARD_ID" | tr -c 'A-Za-z0-9._-' '_')
[[ -z "$SHARD_ID" ]] && SHARD_ID="unknown"

LEDGER="${SESSIONS_DIR}/${SHARD_ID}.jsonl"
# Secrets-at-rest: lock the shard to the owner on first creation.
if [[ ! -e "$LEDGER" ]]; then
  : >> "$LEDGER"
  chmod 600 "$LEDGER" 2> /dev/null || true
fi

jq -cn \
  --arg ts "$TS" \
  --arg session_id "$SESSION_ID" \
  --arg cwd "$CWD_VAL" \
  --arg transcript_path "$TRANSCRIPT" \
  '{ts:$ts,session_id:$session_id,cwd:$cwd,transcript_path:$transcript_path}' \
  >> "$LEDGER"

exit 0
