#!/usr/bin/env bash
# hooks/format-on-save — PostToolUse: auto-format edited files by extension.
#
# Routes on file extension:
#   .sh               -> shfmt -w -i 2                    (format)
#   .ts/.tsx/.js/.jsx -> prettier --write --config <cfg>  (format, see below)
#   .css              -> prettier --write --config <cfg>  (format, see below)
#   other             -> no-op
#
# prettier is project-config-aware but never executes repo config AS CODE.
# Hooks run UNSANDBOXED, so a JS config (prettier.config.js, .prettierrc.cjs,
# …) — or the eslint --fix arm that used to live here (eslint.config.js) — is a
# code-exec vector. The rule:
#   - resolve the edited file's own config via `prettier --find-config-path`;
#   - NO config            -> skip entirely (never apply bare prettier defaults,
#                             which churn repos to double-quote+semi style);
#   - JS config (*.js/.cjs/.mjs/.ts/.mts/.cts) -> skip (would run as code);
#   - data config (.prettierrc, *.json/.json5/.yaml/.yml/.toml, package.json)
#                          -> format with `--config <that file>`.
# Run from the config's directory so `.prettierignore` is honored. A data
# config can still *name* a plugin (prettier loads it) — executing a JS config
# FILE is the vector this blocks; that boundary was a deliberate choice.
#
# Non-gating lint-as-context arm (single-file scope, NEVER blocks):
#   .sh      -> shellcheck
#   .ts/.tsx -> tsc --noEmit on the single file
# Captured stdout, if non-empty, is surfaced via additionalContext only.
# Tools are resolved through mise (mise exec / mise which) so they are the
# pinned toolchain, not an arbitrary PATH binary; a missing tool is skipped.
#
# Missing formatters/linters are silently skipped (command -v / mise which).
# Silent (exit 0, no output) on success or unknown extension.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

if ! command -v jq > /dev/null 2>&1; then
  exit 0
fi

# PostToolUse delivers the path inside tool_input (Edit/Write) or
# tool_response; bare .file_path is kept as a last-resort fallback. Reading
# only .file_path made this hook a silent no-op against real CC payloads.
FILE_PATH=$(printf '%s' "$INPUT" | jq -r '(.tool_input.file_path // .tool_response.filePath // .file_path) // ""')
if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Extract extension (everything after the last dot)
FILENAME=$(basename "$FILE_PATH")
EXT="${FILENAME##*.}"
# If no dot or dot is the first char, ext is empty or the whole name
if [[ "$FILENAME" == "$EXT" ]] || [[ "$FILENAME" == ".$EXT" ]]; then
  EXT=""
fi

# ---------------------------------------------------------------------------
# Tool resolution via mise (pinned toolchain, not arbitrary PATH binary).
#   _have_tool <name>  -> 0 if the tool is resolvable, else 1 (silent skip)
#   _run_tool  <name> ...args -> exec the tool through `mise exec --`
# Falls back to a bare PATH lookup only when mise itself is absent.
# ---------------------------------------------------------------------------
_have_tool() {
  local t="$1"
  if command -v mise > /dev/null 2>&1; then
    mise which "$t" > /dev/null 2>&1 && return 0
  fi
  command -v "$t" > /dev/null 2>&1
}

_run_tool() {
  local t="$1"
  shift
  if command -v mise > /dev/null 2>&1 && mise which "$t" > /dev/null 2>&1; then
    mise exec -- "$t" "$@"
  else
    "$t" "$@"
  fi
}

# ---------------------------------------------------------------------------
# _prettier_format <file>
# Config-aware prettier: format the file with its OWN project config, but only
# when that config is a pure-data file. Skips silently when no config exists
# (never applies bare defaults) or when the config is a JS file (code-exec
# vector — hooks run unsandboxed). Runs from the config's directory so a
# project .prettierignore is honored.
# ---------------------------------------------------------------------------
_prettier_format() {
  local file="$1"
  local fdir fbase cfg cfg_abs cfg_dir cfg_base cfg_ext

  fdir=$(dirname "$file")
  fbase=$(basename "$file")

  # Resolve the config that prettier itself would use for this file. Exits
  # non-zero (and prints to stderr) when none is found -> empty cfg -> skip.
  cfg=$(cd "$fdir" && _run_tool prettier --find-config-path "$fbase" 2> /dev/null) || return 0
  [[ -z "$cfg" ]] && return 0

  # Resolve to an absolute path (find-config-path prints it relative to cwd).
  case "$cfg" in
    /*) cfg_abs="$cfg" ;;
    *) cfg_abs="$fdir/$cfg" ;;
  esac
  # pwd -P (physical): prettier realpath()s the target file before matching it
  # against .prettierignore, so cwd and the file arg must both be resolved
  # through symlinks or the ignore patterns anchor at the wrong root.
  cfg_dir=$(cd "$(dirname "$cfg_abs")" 2> /dev/null && pwd -P) || return 0
  cfg_base=$(basename "$cfg_abs")
  cfg_abs="$cfg_dir/$cfg_base"

  # Reject JS-family config files — loading them executes arbitrary code.
  cfg_ext="${cfg_base##*.}"
  case "$cfg_ext" in
    js | cjs | mjs | ts | mts | cts) return 0 ;;
  esac

  # Data config: format honoring it. Run from the config dir so .prettierignore
  # (resolved relative to cwd) applies. cfg_dir was physicalized via `pwd -P`,
  # so the file must be too — otherwise a symlinked path (e.g. macOS /var ->
  # /private/var) leaves cwd and the file arg with mismatched prefixes and
  # prettier can't anchor the ignore patterns. Best-effort, never blocks.
  local file_dir file_phys
  file_dir=$(cd "$fdir" 2> /dev/null && pwd -P) || return 0
  file_phys="$file_dir/$fbase"
  (cd "$cfg_dir" && _run_tool prettier --write --config "$cfg_abs" "$file_phys") > /dev/null 2>&1 || true
}

# ---------------------------------------------------------------------------
# Format by extension (mutating, best-effort, never blocks)
# ---------------------------------------------------------------------------
case "$EXT" in
  sh)
    # Same flags as the lefthook pre-commit gate (-i 2 -ci -sr) so the hook
    # and the gate can never fight over style.
    if _have_tool shfmt; then
      _run_tool shfmt -w -i 2 -ci -sr "$FILE_PATH" > /dev/null 2>&1 || true
    fi
    ;;

  ts | tsx | js | jsx | css)
    # Config-aware: honor the file's own data-format prettier config, skip when
    # absent (no bare defaults) or when it's a JS config (code-exec vector).
    if _have_tool prettier; then
      _prettier_format "$FILE_PATH"
    fi
    ;;

  *)
    # Unknown extension — no formatter
    ;;
esac

# ---------------------------------------------------------------------------
# Lint-as-context (non-mutating, NEVER blocks, single-file scope).
# Captured stdout, if non-empty, is surfaced via additionalContext only.
# ---------------------------------------------------------------------------
LINT_OUT=""
case "$EXT" in
  sh)
    if _have_tool shellcheck; then
      LINT_OUT=$(_run_tool shellcheck "$FILE_PATH" 2>&1) || true
    fi
    ;;

  ts | tsx)
    if _have_tool tsc; then
      LINT_OUT=$(_run_tool tsc --noEmit "$FILE_PATH" 2>&1) || true
    fi
    ;;

  *) ;;
esac

if [[ -n "$LINT_OUT" ]]; then
  # additionalContext is only documented inside the hookSpecificOutput
  # envelope (with hookEventName); a bare top-level key is not a defined
  # output field and may be ignored.
  jq -n --arg ctx "$LINT_OUT" \
    '{hookSpecificOutput:{hookEventName:"PostToolUse",additionalContext:$ctx}}'
fi

exit 0
