#!/usr/bin/env bash
# hooks/format-on-save — PostToolUse: auto-format edited files by extension.
#
# Routes on file extension:
#   .sh               -> shfmt -w -i 2          (format)
#   .ts/.tsx/.js/.jsx -> prettier --write --no-config   (format)
#   .css              -> prettier --write --no-config   (format)
#   other             -> no-op
#
# Formatters never execute repo-local config: prettier runs --no-config so a
# hostile repo's prettier.config.js / plugins cannot run as code. The eslint
# --fix arm was removed entirely — it auto-exec'd project-local eslint
# (eslint.config.js) UNSANDBOXED, a code-exec vector.
#
# Non-gating lint-as-context arm (single-file scope, NEVER blocks):
#   .sh      -> shellcheck
#   .ts/.tsx -> tsc --noEmit on the single file
# Captured stdout, if non-empty, is surfaced via additionalContext only.
# Tools are resolved through mise (mise exec / mise which) so they are the
# pinned toolchain, not an arbitrary PATH binary; a missing tool is skipped.
#
# Missing formatters/linters are silently skipped (command -v / mise which).
# Silent (exit 0, no output) on success or unknown extension.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

if ! command -v jq > /dev/null 2>&1; then
  exit 0
fi

# PostToolUse delivers the path inside tool_input (Edit/Write) or
# tool_response; bare .file_path is kept as a last-resort fallback. Reading
# only .file_path made this hook a silent no-op against real CC payloads.
FILE_PATH=$(printf '%s' "$INPUT" | jq -r '(.tool_input.file_path // .tool_response.filePath // .file_path) // ""')
if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Extract extension (everything after the last dot)
FILENAME=$(basename "$FILE_PATH")
EXT="${FILENAME##*.}"
# If no dot or dot is the first char, ext is empty or the whole name
if [[ "$FILENAME" == "$EXT" ]] || [[ "$FILENAME" == ".$EXT" ]]; then
  EXT=""
fi

# ---------------------------------------------------------------------------
# Tool resolution via mise (pinned toolchain, not arbitrary PATH binary).
#   _have_tool <name>  -> 0 if the tool is resolvable, else 1 (silent skip)
#   _run_tool  <name> ...args -> exec the tool through `mise exec --`
# Falls back to a bare PATH lookup only when mise itself is absent.
# ---------------------------------------------------------------------------
_have_tool() {
  local t="$1"
  if command -v mise > /dev/null 2>&1; then
    mise which "$t" > /dev/null 2>&1 && return 0
  fi
  command -v "$t" > /dev/null 2>&1
}

_run_tool() {
  local t="$1"
  shift
  if command -v mise > /dev/null 2>&1 && mise which "$t" > /dev/null 2>&1; then
    mise exec -- "$t" "$@"
  else
    "$t" "$@"
  fi
}

# ---------------------------------------------------------------------------
# Format by extension (mutating, best-effort, never blocks)
# ---------------------------------------------------------------------------
case "$EXT" in
  sh)
    # Same flags as the lefthook pre-commit gate (-i 2 -ci -sr) so the hook
    # and the gate can never fight over style.
    if _have_tool shfmt; then
      _run_tool shfmt -w -i 2 -ci -sr "$FILE_PATH" > /dev/null 2>&1 || true
    fi
    ;;

  ts | tsx | js | jsx | css)
    # --no-config: never load (and thus never execute) repo-local prettier
    # config or plugins.
    if _have_tool prettier; then
      _run_tool prettier --write --no-config "$FILE_PATH" > /dev/null 2>&1 || true
    fi
    ;;

  *)
    # Unknown extension — no formatter
    ;;
esac

# ---------------------------------------------------------------------------
# Lint-as-context (non-mutating, NEVER blocks, single-file scope).
# Captured stdout, if non-empty, is surfaced via additionalContext only.
# ---------------------------------------------------------------------------
LINT_OUT=""
case "$EXT" in
  sh)
    if _have_tool shellcheck; then
      LINT_OUT=$(_run_tool shellcheck "$FILE_PATH" 2>&1) || true
    fi
    ;;

  ts | tsx)
    if _have_tool tsc; then
      LINT_OUT=$(_run_tool tsc --noEmit "$FILE_PATH" 2>&1) || true
    fi
    ;;

  *) ;;
esac

if [[ -n "$LINT_OUT" ]]; then
  # additionalContext is only documented inside the hookSpecificOutput
  # envelope (with hookEventName); a bare top-level key is not a defined
  # output field and may be ignored.
  jq -n --arg ctx "$LINT_OUT" \
    '{hookSpecificOutput:{hookEventName:"PostToolUse",additionalContext:$ctx}}'
fi

exit 0
