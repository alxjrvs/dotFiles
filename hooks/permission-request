#!/usr/bin/env bash
# hooks/permission-request — PermissionRequest: auto-allow read-only gh api.
#
# `Bash(gh api *)` sits in permissions.ask, so every gh api call — including
# plain GET reads — raises a dialog. This hook answers ONLY the provably
# read-only subset on the user's behalf and stays silent for everything else
# (no output + exit 0 = normal permission flow; it never denies).
#
# A command is auto-allowed only when ALL hold:
#   1. tool is Bash and the command starts with `gh api `
#   2. no shell metacharacters anywhere (; & | ` $ ( ) < > newline) — a
#      single plain invocation: no chaining, substitution, or redirection
#   3. no body-/method-mutating flags: -f/-F/--field/--raw-field/--input,
#      and -X/--method only with GET. gh api defaults to GET, but any field
#      flag silently flips the request to POST — so fields are banned even
#      though they look read-ish.
#
# Over-rejection is safe by design: anything unusual falls back to the
# normal ask dialog. The allow decision carries no permissionRules — each
# call is judged on its own; nothing persists.
#
# Self-contained: no shared/ sourcing. All helpers defined inline.
set -uo pipefail

# ---------------------------------------------------------------------------
# Read stdin JSON
# ---------------------------------------------------------------------------
INPUT=$(cat)

# Without jq we can't parse the payload — silent pass to the normal dialog.
if ! command -v jq > /dev/null 2>&1; then
  exit 0
fi

TOOL_NAME=$(printf '%s' "$INPUT" | jq -r '.tool_name // ""' 2> /dev/null || true)
COMMAND=$(printf '%s' "$INPUT" | jq -r '.tool_input.command // ""' 2> /dev/null || true)

[[ "$TOOL_NAME" == "Bash" ]] || exit 0
[[ "$COMMAND" == "gh api "* ]] || exit 0

# ---------------------------------------------------------------------------
# Gate 1: single plain command — no metacharacters, no multi-line
# ---------------------------------------------------------------------------
case "$COMMAND" in
  *';'* | *'&'* | *'|'* | *'`'* | *'$'* | *'('* | *')'* | *'<'* | *'>'* | *$'\n'*)
    exit 0
    ;;
esac

# ---------------------------------------------------------------------------
# Gate 2: no body-/method-mutating flags
# ---------------------------------------------------------------------------
# Metacharacters are already excluded, so naive word-splitting is safe for
# flag detection: nothing can hide behind substitution. A flag-looking token
# inside a quoted argument value over-rejects — acceptable (falls back to
# the dialog).
read -ra TOKENS <<< "$COMMAND"
i=0
n=${#TOKENS[@]}
while [[ $i -lt $n ]]; do
  tok="${TOKENS[$i]}"
  # Strip simple quoting so '-f' and "-f" are still caught.
  tok="${tok%\'}"
  tok="${tok#\'}"
  tok="${tok%\"}"
  tok="${tok#\"}"
  case "$tok" in
    -f | -F | --field | --raw-field | --field=* | --raw-field=* | --input | --input=*)
      exit 0
      ;;
    -X | --method)
      next="${TOKENS[$((i + 1))]:-}"
      next="${next%\'}"
      next="${next#\'}"
      next="${next%\"}"
      next="${next#\"}"
      case "$next" in
        GET | get) ;;
        *) exit 0 ;;
      esac
      ;;
    -X=* | --method=* | -X*)
      val="${tok#-X}"
      val="${val#=}"
      val="${val#--method=}"
      case "$val" in
        GET | get) ;;
        *) exit 0 ;;
      esac
      ;;
  esac
  i=$((i + 1))
done

# ---------------------------------------------------------------------------
# Verdict: read-only gh api GET — answer the dialog with allow
# ---------------------------------------------------------------------------
jq -n '{hookSpecificOutput:{hookEventName:"PermissionRequest",decision:{behavior:"allow"}}}'

exit 0
