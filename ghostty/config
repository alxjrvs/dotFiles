# Ghostty.app config — the daily-driver terminal. Read from
# ~/.config/ghostty/config (a fixed path, no override). cmux, kept installed for
# parallel agent sessions, embeds libghostty and reads this same file but honors
# only the visual subset (theme/font/colors/opacity/splits/scrollback) — it
# ignores the keybinds and quick-terminal visor below, which are Ghostty.app
# only. cmux app behavior lives in cmux/cmux.json.

# Theme
theme = Nord

# Font
font-family = FiraCode Nerd Font
font-thicken = true
font-size = 14

# Ligatures (disabled by default since v1.2.0)
font-feature = +liga
font-feature = +calt
font-feature = +dlig
adjust-cell-height = -1

# Cursor
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# Window
window-padding-x = 0
window-padding-y = 0
window-padding-balance = false
macos-titlebar-style = native
window-save-state = always
confirm-close-surface = true
quit-after-last-window-closed = true
macos-option-as-alt = left

# Clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false
copy-on-select = true

# Scrollback
scrollback-limit = 10000

shell-integration = zsh

# Quick terminal — drop-down visor toggled by a global hotkey. Pairs with
# Raycast for zero-latency context switching; no app launch needed for a
# 10-second command. `global:` makes the keybind work even when Ghostty
# isn't focused.
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# Keybindings
keybind = ctrl+shift+w=close_surface
keybind = global:ctrl+grave_accent=toggle_quick_terminal
