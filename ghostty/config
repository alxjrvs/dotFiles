# Terminal-rendering config for cmux (the daily driver), which embeds
# libghostty and reads this file from ~/.config/ghostty/config — a fixed path,
# no override. cmux honors only the visual subset (theme/font/colors/opacity/
# splits/scrollback), so keybinds and the quick-terminal visor live nowhere
# here. cmux app behavior is in cmux/cmux.json; standalone Ghostty.app, if
# launched, also reads this.

# Theme
theme = Nord

# Font
font-family = FiraCode Nerd Font
font-thicken = true
font-size = 14

# Ligatures (disabled by default since v1.2.0)
font-feature = +liga
font-feature = +calt
font-feature = +dlig
adjust-cell-height = -1

# Cursor
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# Window
window-padding-x = 0
window-padding-y = 0
window-padding-balance = false
macos-titlebar-style = native
window-save-state = always
confirm-close-surface = true
quit-after-last-window-closed = true
macos-option-as-alt = left

# Clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false
copy-on-select = true

# Scrollback
scrollback-limit = 10000

shell-integration = zsh
