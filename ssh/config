# ~/.ssh/config — symlinked from dotfiles. Permissions: 600.
#
# Augment remote agent SSH connections (externally managed; preserve at top).
Include ~/.augment/ssh-config

Host *
  # Add keys to ssh-agent on first use; keep passphrase cached.
  AddKeysToAgent yes

  # 1Password SSH agent: keys live in 1Password, touch-to-sign on each use.
  # Requires "SSH agent" enabled in 1Password → Settings → Developer.
  # Replaces UseKeychain + IdentityFile semantics.
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

  # Keep idle connections alive (NAT/firewall friendly).
  ServerAliveInterval 60
  ServerAliveCountMax 3

  # Connection multiplexing — second `git push` reuses the first connection.
  ControlMaster auto
  # Sockets live in /tmp (user-private 600) — avoids ~/.ssh/ if its perms ever drift.
  ControlPath /tmp/ssh-cm-%r@%h:%p
  ControlPersist 10m

Host github.com
  User git
  # Explicit entry so future per-org keys / settings have a place to land.
  # Inherits IdentityAgent from Host * above.
