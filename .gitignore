# Claude
.claude/*.local.json
.claude/worktrees/

# `.secrets` was decommissioned in favor of op-run / op:// (see CLAUDE.md).
# `.npmrc` is gitignored at the user-config level because per-project
# `.npmrc`s belong to those projects' repos (with op:// refs if they need
# credentials). A user-level `.npmrc` would mostly hold registry-auth
# state we don't want bleeding across projects.
.npmrc

# Transient/generated
.playwright-mcp/
.gnar-term/
Brewfile.lock.json

# Machine-specific overrides
dot-claude/settings.local.json
**/.claude/settings.local.json

# Rust build artifacts (dotctl)
# Cargo.lock IS committed for the dotctl binary crate — pins transitive
# dep versions across `cargo install` on fresh machines.
dotctl/target/
