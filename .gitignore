# Claude — this repo's own project-scoped `.claude/` is machine-local; the
# user/global config lives in `dot-claude/`, symlinked into ~/.claude/ by
# `botu apply`. (Repo-scoped only — global excludes live in `git/ignore`, NOT
# a blanket `.claude/` that would hide it in every repo on the machine.)
.claude/

# Transient/generated
Brewfile.lock.json

# Generated audit reports (gnar audit plugin) — regenerate on demand, not tracked.
audit/

# Machine-specific overrides
dot-claude/settings.local.json
**/.claude/settings.local.json
