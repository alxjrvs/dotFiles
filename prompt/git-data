#!/usr/bin/env bash
# git-data — gather git state and write a shell-sourceable cache.
#
# Gathers git state in a single pass and writes a shell-sourceable cache file
# at $(xdg_cache_home)/git-data/<repo-hash>.sh (mode 600, dir 700). Cache key
# is the repo toplevel (or cwd if outside a repo). The cache filename hash is
# the inlined repo_hash below — prompt-render inlines the identical function
# so producer and consumer agree (the statusline gathers its own git state
# and does not read this cache).
#
# Variables emitted (KEY='value', single-quoted):
#   GIT_IS_REPO, GIT_IS_WORKTREE, GIT_WORKTREE_NAME, GIT_DIR,
#   GIT_TOPLEVEL, GIT_BRANCH, GIT_REPO_NAME,
#   GIT_REPO_HTTPS, GIT_CONFLICT_COUNT, GIT_STAGED_COUNT,
#   GIT_UNSTAGED_COUNT, GIT_UNTRACKED_COUNT, GIT_STASH_COUNT,
#   GIT_AHEAD, GIT_BEHIND, GIT_CACHE_TIME,
#   GIT_PR_STATUS (pass|pending|fail|""), GIT_PR_URL, GIT_PR_NUMBER,
#   GIT_PR_CHECKED_AT
#
# A leading "git-data" positional arg (from `dot git-data` dispatch) is
# accepted and ignored.

set -euo pipefail

# ── Inlined cache-path helper (self-contained: no shared/ sourcing) ──
#
# Cache filename hash: 12 hex chars of FNV-1a over the repo toplevel (or cwd
# when outside a repo). prompt-render inlines the identical function so
# producer and consumer agree on the cache file.

# xdg_cache_home — $XDG_CACHE_HOME or $HOME/.cache fallback.
xdg_cache_home() {
  if [[ -n "${XDG_CACHE_HOME:-}" ]]; then
    printf '%s' "$XDG_CACHE_HOME"
  else
    printf '%s' "${HOME:-.}/.cache"
  fi
}

# repo_hash PATH [OUTVAR] — 12-hex cache key: FNV-1a 64-bit over the path
# characters, low 48 bits, pure bash (no fork — this replaced a shasum|cut
# pipeline so prompt-render stays subprocess-free). With OUTVAR the result is
# assigned via printf -v instead of printed. prompt-render inlines the
# IDENTICAL function (bats asserts it).
repo_hash() {
  local path="$1" out="${2:-}"
  local -i h=-3750763034362895579 prime=1099511628211 c # 0xcbf29ce484222325
  local i
  for ((i = 0; i < ${#path}; i++)); do
    printf -v c '%d' "'${path:i:1}"
    ((h ^= c, h *= prime)) || true
  done
  if [[ -n "$out" ]]; then
    printf -v "$out" '%012x' $((h & 0xFFFFFFFFFFFF))
  else
    printf '%012x' $((h & 0xFFFFFFFFFFFF))
  fi
}

# git_cache_path TOPLEVEL — resolve the cache file path for a repo toplevel
# (falls back to cwd when empty). Creates the cache dir (mode 700) as a side
# effect.
git_cache_path() {
  local toplevel="$1" key
  if [[ -n "$toplevel" ]]; then
    key="$toplevel"
  else
    key="$(pwd)"
  fi
  local short
  short="$(repo_hash "$key")"
  local cache_dir
  cache_dir="$(xdg_cache_home)/git-data"
  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir" 2> /dev/null || true
  printf '%s/%s.sh' "$cache_dir" "$short"
}

# PR status freshness — gh costs ~1s per call. With 60s TTL we hit gh once
# per minute per repo; prompt/statusline pick up cached values the rest of
# the time. Skipped entirely when not in a repo (gh would error anyway).
PR_TTL_SECS=60

# ── Gathered state (defaults match GitData::default) ──
G_IS_REPO=""
G_IS_WORKTREE=""
G_WORKTREE_NAME=""
G_DIR=""
G_TOPLEVEL=""
G_BRANCH=""
G_REPO_NAME=""
G_REPO_HTTPS=""
G_CONFLICT_COUNT=0
G_STAGED_COUNT=0
G_UNSTAGED_COUNT=0
G_UNTRACKED_COUNT=0
G_STASH_COUNT=0
G_AHEAD=0
G_BEHIND=0
G_PR_STATUS=""
G_PR_URL=""
G_PR_NUMBER=0
G_PR_CHECKED_AT=0

# git ARGS... — echo stdout, return non-zero on failure (no stderr).
# GIT_OPTIONAL_LOCKS=0: background refreshes must never contend for
# index.lock with the session's own git rebase/add.
export GIT_OPTIONAL_LOCKS=0
git_cmd() {
  git "$@" 2> /dev/null
}

# trim — strip leading + trailing ASCII/Unicode whitespace (Rust str::trim).
trim() {
  local s="$1"
  while [[ -n "$s" && "${s:0:1}" == [[:space:]] ]]; do s="${s:1}"; done
  while [[ -n "$s" && "${s: -1}" == [[:space:]] ]]; do s="${s:0:${#s}-1}"; done
  printf '%s' "$s"
}

# tally XY — classify a porcelain v2 XY pair into conflict/staged/unstaged.
# Conflict patterns short-circuit before staged/unstaged classification.
tally() {
  local xy="$1"
  local x="${xy:0:1}"
  local y="${xy:1:1}"
  case "$xy" in
    UU | AA | DD | AU | UA | DU | UD)
      G_CONFLICT_COUNT=$((G_CONFLICT_COUNT + 1))
      return
      ;;
  esac
  case "$x" in
    M | A | D | R | C) G_STAGED_COUNT=$((G_STAGED_COUNT + 1)) ;;
  esac
  case "$y" in
    M | D) G_UNSTAGED_COUNT=$((G_UNSTAGED_COUNT + 1)) ;;
  esac
}

gather() {
  local rev
  if ! rev=$(git_cmd rev-parse --git-dir --git-common-dir --show-toplevel); then
    return 0 # not a repo — defaults are fine
  fi

  local -a lines=()
  local l
  while IFS= read -r l; do lines+=("$l"); done <<< "$rev"
  if ((${#lines[@]} < 3)); then
    return 0
  fi
  G_IS_REPO=1
  G_DIR="${lines[0]}"
  local common_dir="${lines[1]}"
  G_TOPLEVEL="${lines[2]}"

  if [[ "$G_DIR" != "$common_dir" ]]; then
    G_IS_WORKTREE=1
    G_WORKTREE_NAME="${G_TOPLEVEL##*/}"
  fi

  # Single git call for branch + ahead/behind + porcelain.
  local status
  status=$(git_cmd status --porcelain=v2 --branch --ahead-behind || true)

  local line rest
  while IFS= read -r line; do
    if [[ "$line" == "# branch.head "* ]]; then
      G_BRANCH="${line#\# branch.head }"
    elif [[ "$line" == "# branch.ab "* ]]; then
      rest="${line#\# branch.ab }"
      # Format: "+<ahead> -<behind>"
      local -a ab=()
      read -r -a ab <<< "$rest"
      if ((${#ab[@]} == 2)); then
        local a="${ab[0]#+}" b="${ab[1]#-}"
        [[ "$a" =~ ^[0-9]+$ ]] && G_AHEAD="$a" || G_AHEAD=0
        [[ "$b" =~ ^[0-9]+$ ]] && G_BEHIND="$b" || G_BEHIND=0
      fi
    fi
  done <<< "$status"

  # Detached HEAD fallback.
  if [[ -z "$G_BRANCH" || "$G_BRANCH" == "(detached)" ]]; then
    local short
    if short=$(git_cmd rev-parse --short HEAD); then
      # Trim trailing whitespace/newline.
      G_BRANCH="${short%%[[:space:]]*}"
    fi
  fi

  # Remote URL → HTTPS + name.
  local remote
  if remote=$(git_cmd remote get-url origin); then
    remote="${remote%%$'\n'*}"
    remote="$(trim "$remote")"
    if [[ -n "$remote" ]]; then
      local https="${remote/git@github.com:/https:\/\/github.com\/}"
      # strip_suffix(".git") — only when present.
      https="${https%.git}"
      G_REPO_HTTPS="$https"
      G_REPO_NAME="${https##*/}"
    fi
  fi

  # Tally porcelain entries. Only the XY pair matters — nothing consumes the
  # paths, so they are never extracted (the old char-by-char path walk was the
  # most expensive code on the prompt hot path for dirty repos).
  local kind xy
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    [[ "$line" == "#"* ]] && continue
    kind="${line:0:1}"
    case "$kind" in
      1 | 2 | u)
        xy="${line:2:2}"
        tally "$xy"
        ;;
      '?')
        G_UNTRACKED_COUNT=$((G_UNTRACKED_COUNT + 1))
        ;;
    esac
  done <<< "$status"

  # Stash count (non-empty lines).
  local stash
  if stash=$(git_cmd stash list); then
    local n=0 sl
    while IFS= read -r sl; do
      [[ -n "$sl" ]] && n=$((n + 1))
    done <<< "$stash"
    G_STASH_COUNT="$n"
  fi
}

# Query gh for the current branch's PR status. Sets G_PR_STATUS / G_PR_URL /
# G_PR_NUMBER. Degrades to ("","",0) when gh is missing/unauthenticated or no
# PR exists.
query_pr_status() {
  G_PR_STATUS=""
  G_PR_URL=""
  G_PR_NUMBER=0
  command -v gh > /dev/null 2>&1 || return 0

  local jq_expr
  # shellcheck disable=SC2016  # jq program: $checks/$s are jq vars, not shell.
  jq_expr='
        if .currentBranch == null then "" else
            (.currentBranch.statusCheckRollup // []) as $checks |
            (if   ($checks | any(.conclusion == "FAILURE")) then "fail"
             elif ($checks | length == 0) then "pending"
             elif ($checks | any(.conclusion == null or .conclusion == "")) then "pending"
             else "pass" end) as $s |
            $s + "\t" + (.currentBranch.url // "") + "\t" + ((.currentBranch.number // 0) | tostring)
        end
    '
  local out
  if ! out=$(gh pr status --json statusCheckRollup,number,url --jq "$jq_expr" 2> /dev/null); then
    return 0
  fi
  out="$(trim "$out")"
  [[ -z "$out" ]] && return 0

  local -a parts=()
  local IFS=$'\t'
  read -r -a parts <<< "$out"
  if ((${#parts[@]} != 3)); then
    return 0
  fi
  G_PR_STATUS="${parts[0]}"
  G_PR_URL="${parts[1]}"
  if [[ "${parts[2]}" =~ ^[0-9]+$ ]]; then
    G_PR_NUMBER="${parts[2]}"
  else
    G_PR_NUMBER=0
  fi
}

# Prior PR fields parsed from an existing cache file by read_existing_pr_data.
# Named globals are used instead of round-tripping a tab-joined string through
# `read`: under bash 3.2, `read -a` collapses leading empty IFS fields, so a
# no-PR record ("\t\t0\t<epoch>") would parse to 2 elements and lose the
# timestamp — making the TTL check always miss and re-invoke gh every prompt.
G_PRIOR_STATUS=""
G_PRIOR_URL=""
G_PRIOR_NUMBER=0
G_PRIOR_CHECKED_AT=0

# Read prior PR fields from an existing cache file into the G_PRIOR_* globals.
# Returns 0 only when all four fields are present and number/checked_at parse
# as integers (mirrors read_existing_pr_data Some(...) semantics). On any
# failure the globals are left at their defaults and the caller re-queries.
read_existing_pr_data() {
  local cache_file="$1"
  G_PRIOR_STATUS=""
  G_PRIOR_URL=""
  G_PRIOR_NUMBER=0
  G_PRIOR_CHECKED_AT=0
  [[ -f "$cache_file" ]] || return 1
  local status="" url="" number="" checked_at=""
  local have_s=0 have_u=0 have_n=0 have_c=0
  local line v
  while IFS= read -r line; do
    if v=$(single_quoted_value "$line" "GIT_PR_STATUS="); then
      status="$v"
      have_s=1
    elif v=$(single_quoted_value "$line" "GIT_PR_URL="); then
      url="$v"
      have_u=1
    elif v=$(single_quoted_value "$line" "GIT_PR_NUMBER="); then
      number="$v"
      have_n=1
    elif v=$(single_quoted_value "$line" "GIT_PR_CHECKED_AT="); then
      checked_at="$v"
      have_c=1
    fi
  done < "$cache_file"
  ((have_s && have_u && have_n && have_c)) || return 1
  # number / checked_at must parse as integers (Rust .parse().ok()? on u32/u64).
  [[ "$number" =~ ^[0-9]+$ ]] || return 1
  [[ "$checked_at" =~ ^[0-9]+$ ]] || return 1
  G_PRIOR_STATUS="$status"
  G_PRIOR_URL="$url"
  G_PRIOR_NUMBER="$number"
  G_PRIOR_CHECKED_AT="$checked_at"
}

# Extract the single-quoted value from a `KEY='value'` line. Returns non-zero
# when the prefix doesn't match or quotes are malformed (mirrors the Rust
# single_quoted_value Option).
single_quoted_value() {
  local line="$1" prefix="$2"
  [[ "$line" == "$prefix"* ]] || return 1
  local rest="${line#"$prefix"}"
  [[ "$rest" == "'"*"'" ]] || return 1
  rest="${rest#\'}"
  rest="${rest%\'}"
  printf '%s' "$rest"
}

# Single-quote escape: ' -> '\''.
esc() {
  local s="$1"
  printf '%s' "${s//\'/\'\\\'\'}"
}

# Local-time human stamp for the cache header (informational; consumers don't
# parse it). Uses the macOS `date` default format.
human_time() {
  local epoch="$1"
  date -r "$epoch" '+%a %b %e %H:%M:%S %Z %Y' 2> /dev/null ||
    date -d "@$epoch" '+%a %b %e %H:%M:%S %Z %Y' 2> /dev/null ||
    printf '%s' "$epoch"
}

write_cache() {
  local path="$1"
  local now="$2"
  local now_human
  now_human=$(human_time "$now")

  local cache_dir
  cache_dir=$(dirname "$path")
  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir" 2> /dev/null || true

  local tmp="${path}.$$.tmp"
  # Create with mode 600 from the start.
  (
    umask 077
    : > "$tmp"
  )
  {
    printf '# git-data cache — generated by dot git-data\n'
    printf '# Generated: %s\n' "$now_human"
    printf "GIT_CACHE_TIME='%s'\n" "$now"
    printf "GIT_IS_REPO='%s'\n" "$(esc "$G_IS_REPO")"
    printf "GIT_IS_WORKTREE='%s'\n" "$(esc "$G_IS_WORKTREE")"
    printf "GIT_WORKTREE_NAME='%s'\n" "$(esc "$G_WORKTREE_NAME")"
    printf "GIT_DIR='%s'\n" "$(esc "$G_DIR")"
    printf "GIT_TOPLEVEL='%s'\n" "$(esc "$G_TOPLEVEL")"
    printf "GIT_BRANCH='%s'\n" "$(esc "$G_BRANCH")"
    printf "GIT_REPO_NAME='%s'\n" "$(esc "$G_REPO_NAME")"
    printf "GIT_REPO_HTTPS='%s'\n" "$(esc "$G_REPO_HTTPS")"
    printf "GIT_CONFLICT_COUNT='%s'\n" "$G_CONFLICT_COUNT"
    printf "GIT_STAGED_COUNT='%s'\n" "$G_STAGED_COUNT"
    printf "GIT_UNSTAGED_COUNT='%s'\n" "$G_UNSTAGED_COUNT"
    printf "GIT_UNTRACKED_COUNT='%s'\n" "$G_UNTRACKED_COUNT"
    printf "GIT_STASH_COUNT='%s'\n" "$G_STASH_COUNT"
    printf "GIT_AHEAD='%s'\n" "$G_AHEAD"
    printf "GIT_BEHIND='%s'\n" "$G_BEHIND"
    printf "GIT_PR_STATUS='%s'\n" "$(esc "$G_PR_STATUS")"
    printf "GIT_PR_URL='%s'\n" "$(esc "$G_PR_URL")"
    printf "GIT_PR_NUMBER='%s'\n" "$G_PR_NUMBER"
    printf "GIT_PR_CHECKED_AT='%s'\n" "$G_PR_CHECKED_AT"
  } > "$tmp"

  if ! mv -f "$tmp" "$path"; then
    rm -f "$tmp"
    return 1
  fi
  chmod 600 "$path" 2> /dev/null || true
}

main() {
  gather

  local cache_file
  cache_file=$(git_cache_path "$G_TOPLEVEL")

  local now
  now=$(date +%s)

  # PR-status freshness: reuse cached values if checked within TTL.
  # read_existing_pr_data sets G_PRIOR_* globals (no tab-joined round-trip —
  # see the note above its definition for the bash 3.2 `read` collapse bug).
  #
  # DOT_GIT_DATA_SKIP_PR=1 serves stale PR data unconditionally and never
  # invokes gh. The zsh precmd sets it on the FOREGROUND refresh (which runs
  # before the prompt draws — an expired TTL used to mean a ~1s gh call
  # freezing the prompt right after every commit); the background refresh
  # runs without it and keeps PR data current.
  if [[ -n "$G_IS_REPO" ]]; then
    local age
    if read_existing_pr_data "$cache_file"; then
      age=$((now - G_PRIOR_CHECKED_AT))
      ((age < 0)) && age=0 # saturating_sub
      if ((age < PR_TTL_SECS)) || [[ "${DOT_GIT_DATA_SKIP_PR:-}" == "1" ]]; then
        G_PR_STATUS="$G_PRIOR_STATUS"
        G_PR_URL="$G_PRIOR_URL"
        G_PR_NUMBER="$G_PRIOR_NUMBER"
        G_PR_CHECKED_AT="$G_PRIOR_CHECKED_AT"
      else
        query_pr_status
        G_PR_CHECKED_AT="$now"
      fi
    elif [[ "${DOT_GIT_DATA_SKIP_PR:-}" == "1" ]]; then
      : # no prior PR data and the refresh is deferred — defaults stay, and
      # GIT_PR_CHECKED_AT=0 makes the next background refresh query at once
    else
      query_pr_status
      G_PR_CHECKED_AT="$now"
    fi
  fi

  write_cache "$cache_file" "$now"
}

main "$@"
