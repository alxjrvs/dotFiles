#!/usr/bin/env bash
# prompt-render — read the git-data cache and emit zsh PROMPT syntax.
#
# Reads the git-data cache (located by hashing the repo toplevel) and emits a
# powerline zsh PROMPT string with %{...%} escapes so zsh's width calculator
# ignores the escape bytes. Pure string assembly — makes zero subprocess calls:
# the cache lookup walks PWD upward for a .git entry in-process, and every
# fg/bg/osc8 escape is appended to OUT directly rather than via $(...).
#
# Layout (Nord palette): opening wedge → repo/cwd cell → optional PR cell →
# branch pill → optional worktree cell → status pips → closing arrow.
#
# A leading "prompt-render" positional arg (from `dot prompt-render` dispatch
# or the golden harness `$BINARY prompt-render`) is accepted and ignored.

set -euo pipefail

# ── Inlined cache-path + cache-load helpers (self-contained) ──
#
# Hash the repo toplevel (or cwd), locate $XDG_CACHE_HOME/git-data/<hash>.sh,
# and source it to populate GIT_*. The hash function matches prompt/git-data so
# they agree on the cache file. The toplevel is found by walking PWD upward for
# a .git entry in-process (no `git` subprocess), matching the key git-data uses
# (`git rev-parse --show-toplevel`) for both plain checkouts and worktrees.

# repo_hash PATH [OUTVAR] — 12-hex cache key: FNV-1a 64-bit over the path
# characters, low 48 bits, pure bash. IDENTICAL to the function in
# prompt/git-data (bats asserts it); the render path calls it with OUTVAR
# so even the hash costs no subshell.
repo_hash() {
  local path="$1" out="${2:-}"
  local -i h=-3750763034362895579 prime=1099511628211 c # 0xcbf29ce484222325
  local i
  for ((i = 0; i < ${#path}; i++)); do
    printf -v c '%d' "'${path:i:1}"
    ((h ^= c, h *= prime)) || true
  done
  if [[ -n "$out" ]]; then
    printf -v "$out" '%012x' $((h & 0xFFFFFFFFFFFF))
  else
    printf '%012x' $((h & 0xFFFFFFFFFFFF))
  fi
}

# find_toplevel — walk PWD upward until a directory contains a .git entry (dir
# for a plain checkout, file for a linked worktree), setting _toplevel. Empty
# when no .git is found (outside a repo). Pure bash, no fork — reproduces the
# `git rev-parse --show-toplevel` value git-data keys the cache on for the
# common cases the prompt cares about.
find_toplevel() {
  _toplevel=""
  local dir="${PWD:-}"
  [[ -n "$dir" ]] || dir="$(pwd)"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -e "$dir/.git" ]]; then
      _toplevel="$dir"
      return 0
    fi
    dir="${dir%/*}"
  done
  [[ -e "/.git" ]] && _toplevel="/"
  return 0
}

# load_git_cache — resolve the cache for the repo containing cwd and source it
# (sets GIT_* vars). Silent no-op when outside a repo or the cache is absent.
# An empty toplevel falls back to PWD as the cache key. Every step is in-
# process: this script's contract is fork-free (read cache, render, exit).
load_git_cache() {
  find_toplevel
  local key="${_toplevel:-${PWD:-.}}"
  local short
  repo_hash "$key" short
  local cache_file="${XDG_CACHE_HOME:-${HOME:-.}/.cache}/git-data/${short}.sh"
  if [[ -f "$cache_file" ]]; then
    # shellcheck disable=SC1090  # path is computed at runtime.
    source "$cache_file"
  fi
}

# ── ANSI escape primitives (wrapped in zsh %{...%}) ──────────────────────────
RST='%{'$'\033''[0m%}'
UL='%{'$'\033''[4m%}'
NUL='%{'$'\033''[24m%}'

# Powerline glyphs (Nerd Font PUA range).
ARROW_R=$'\xee\x82\xb0' # U+E0B0 right triangle separator
WEDGE_O=$'\xee\x82\xba' # U+E0BA opening wedge (concave)
GH_ICON=$'\xef\x82\x9b' # U+F09B GitHub mark

# ── Nord-derived RGB triples ────────────────────────────────────────────────
TERM_BG='46;52;64'         # #2E3440 — Nord 0 terminal bg
SS1='216;222;233'          # #D8DEE9 — Snow Storm 1
FG_LIGHT='236;239;244'     # #ECEFF4 — Nord 6
FG_DARK='46;52;64'         # dark text on SS1
NORD_1='59;66;82'          # #3B4252 — fallback PR cell bg
NOVA_WORKTREE='94;129;172' # #5E81AC — Nord 10
NOVA_BG='46;52;64'         # same as TERM_BG

# PR status palette
PR_PASS='163;190;140'    # Nord 14
PR_PENDING='235;203;139' # Nord 13
PR_FAIL='191;97;106'     # Nord 11

# Git status pip colors. Prefixed C_ so they don't collide with the GIT_*
# cache variables sourced by load_git_cache (e.g. GIT_AHEAD holds a count).
C_GIT_STASH='180;142;173'     # Nord 15
C_GIT_CONFLICT='191;97;106'   # Nord 11
C_GIT_STAGED='163;190;140'    # Nord 14
C_GIT_UNSTAGED='235;203;139'  # Nord 13
C_GIT_UNTRACKED='129;161;193' # Nord 9
C_GIT_AHEAD='208;135;112'     # Nord 12
C_GIT_BEHIND='94;129;172'     # Nord 10
C_GIT_CLEAN='163;190;140'     # Nord 14

UP_ARROW=$'\xe2\x86\x91'   # U+2191 up arrow (ahead)
DOWN_ARROW=$'\xe2\x86\x93' # U+2193 down arrow (behind)
CHECK=$'\xe2\x9c\x93'      # U+2713 check (clean)

# fg/bg/osc8 append zsh-wrapped escapes directly onto OUT (no $(...) fork on the
# render path). fg/bg take a "R;G;B" triple; osc8_open takes a URL.
ESC=$'\033'
ESC_BEL=$'\a'
fg() { OUT+="%{${ESC}[38;2;$1m%}"; }
bg() { OUT+="%{${ESC}[48;2;$1m%}"; }
osc8_open() { OUT+="%{${ESC}]8;;$1${ESC_BEL}%}"; }
osc8_close() { OUT+="%{${ESC}]8;;${ESC_BEL}%}"; }

# num VAR OUT — copy a u32 cache var into OUT (0 when unset / non-numeric)
# via printf -v: no subshell on the render path. String cache vars are read
# with plain ${VAR:-} expansions for the same reason — the old $(gv/gu)
# substitutions forked ~18 subshells per render.
num() {
  local v="${!1:-}"
  [[ "$v" =~ ^[0-9]+$ ]] || v=0
  printf -v "$2" '%s' "$v"
}

OUT=""

render_repo_dir() {
  local repo_name="${GIT_REPO_NAME:-}"
  local repo_https="${GIT_REPO_HTTPS:-}"
  local pr_status="${GIT_PR_STATUS:-}"
  local pr_url="${GIT_PR_URL:-}"
  local is_repo
  [[ "${GIT_IS_REPO:-}" == "1" ]] && is_repo=1 || is_repo=0

  local pr_bg pr_fg
  case "$pr_status" in
    pass)
      pr_bg="$PR_PASS"
      pr_fg="$FG_DARK"
      ;;
    pending)
      pr_bg="$PR_PENDING"
      pr_fg="$FG_DARK"
      ;;
    fail)
      pr_bg="$PR_FAIL"
      pr_fg="$FG_LIGHT"
      ;;
    *)
      pr_bg="$NORD_1"
      pr_fg="$FG_LIGHT"
      ;;
  esac

  # Opening wedge from terminal bg into SS1 cell.
  bg "$TERM_BG"
  fg "$SS1"
  OUT+="$WEDGE_O"

  # SS1 cell with dark text.
  bg "$SS1"
  fg "$FG_DARK"

  if [[ -n "$repo_name" ]]; then
    OUT+=" "
    OUT+="$UL"
    osc8_open "$repo_https"
    OUT+="$repo_name"
    osc8_close
    OUT+="$NUL"
    OUT+=" "

    # SS1 → PR cell arrow.
    bg "$pr_bg"
    fg "$SS1"
    OUT+="$ARROW_R"

    # GH icon, optionally OSC8-linked to PR URL.
    fg "$pr_fg"
    OUT+=" "
    if [[ -n "$pr_url" ]]; then
      osc8_open "$pr_url"
      OUT+="$GH_ICON"
      osc8_close
    else
      OUT+="$GH_ICON"
    fi
    OUT+=" "
  else
    # Bare CWD fallback: last 2 path components, no link.
    OUT+=" "
    cwd_display
    OUT+=" "
    if ((is_repo == 0)); then
      OUT+="$RST"
      fg "$SS1"
      OUT+="$ARROW_R"
      OUT+="$RST"
    fi
  fi
}

render_git_seg() {
  [[ "${GIT_IS_REPO:-}" == "1" ]] || return 0

  local branch="${GIT_BRANCH:-}"
  local repo_name="${GIT_REPO_NAME:-}"
  local pr_status="${GIT_PR_STATUS:-}"

  local from_color
  if [[ -n "$repo_name" ]]; then
    case "$pr_status" in
      pass) from_color="$PR_PASS" ;;
      pending) from_color="$PR_PENDING" ;;
      fail) from_color="$PR_FAIL" ;;
      *) from_color="$NORD_1" ;;
    esac
  else
    from_color="$SS1"
  fi

  bg "$SS1"
  fg "$from_color"
  OUT+="$ARROW_R"
  fg "$FG_DARK"
  OUT+=" "
  OUT+="$branch"
  OUT+=" "
  local prev="$SS1"

  # Worktree cell: STATUSLINE_WORKTREE env overrides; else GIT_IS_WORKTREE.
  local wt_label
  if [[ -n "${STATUSLINE_WORKTREE:-}" ]]; then
    wt_label="$STATUSLINE_WORKTREE"
  elif [[ "${GIT_IS_WORKTREE:-}" == "1" ]]; then
    wt_label="${GIT_WORKTREE_NAME:-}"
  else
    wt_label=""
  fi
  if [[ -n "$wt_label" ]]; then
    bg "$NOVA_WORKTREE"
    fg "$prev"
    OUT+="$ARROW_R"
    fg "$NOVA_BG"
    OUT+=" "
    OUT+="$wt_label"
    OUT+=" "
    prev="$NOVA_WORKTREE"
  fi

  local stash conflict untracked unstaged staged ahead behind
  num GIT_STASH_COUNT stash
  num GIT_CONFLICT_COUNT conflict
  num GIT_UNTRACKED_COUNT untracked
  num GIT_UNSTAGED_COUNT unstaged
  num GIT_STAGED_COUNT staged
  num GIT_AHEAD ahead
  num GIT_BEHIND behind

  local any=0
  ((stash > 0)) && {
    any=1
    push_pip "$C_GIT_STASH" "\$${stash}"
  }
  ((conflict > 0)) && {
    any=1
    push_pip "$C_GIT_CONFLICT" "!${conflict}"
  }
  ((untracked > 0)) && {
    any=1
    push_pip "$C_GIT_UNTRACKED" "?${untracked}"
  }
  ((unstaged > 0)) && {
    any=1
    push_pip "$C_GIT_UNSTAGED" "~${unstaged}"
  }
  ((staged > 0)) && {
    any=1
    push_pip "$C_GIT_STAGED" "+${staged}"
  }
  ((ahead > 0)) && {
    any=1
    push_pip "$C_GIT_AHEAD" "${UP_ARROW}${ahead}"
  }
  ((behind > 0)) && {
    any=1
    push_pip "$C_GIT_BEHIND" "${DOWN_ARROW}${behind}"
  }
  if ((any == 0)); then
    push_pip "$C_GIT_CLEAN" "$CHECK"
  fi

  # Closing arrow.
  OUT+="$RST"
  fg "$prev"
  OUT+="$ARROW_R"
  OUT+="$RST"
}

# push_pip COLOR LABEL — emits one status pip cell, advancing $prev (caller var).
push_pip() {
  local color="$1" label="$2"
  bg "$color"
  fg "$prev"
  OUT+="$ARROW_R"
  fg "$NOVA_BG"
  OUT+=" "
  OUT+="$label"
  OUT+=" "
  prev="$color"
}

# Append the last 2 path components of PWD (with ~ for $HOME) onto OUT.
cwd_display() {
  local pwd_v="${PWD:-.}"
  local home="${HOME:-}"
  local shown
  if [[ -n "$home" && "$pwd_v" == "$home"* ]]; then
    local rel="${pwd_v:${#home}}"
    if [[ -z "$rel" ]]; then
      shown="~"
    else
      shown="~$rel"
    fi
  else
    shown="$pwd_v"
  fi

  # Split on '/', dropping empty fields.
  local -a parts=()
  local IFS='/'
  local seg
  for seg in $shown; do
    [[ -n "$seg" ]] && parts+=("$seg")
  done
  local n=${#parts[@]}

  if [[ "$shown" == "~"* ]]; then
    if ((n >= 3)); then
      OUT+="${parts[n - 2]}/${parts[n - 1]}"
    else
      OUT+="$shown"
    fi
  elif ((n >= 2)); then
    OUT+="${parts[n - 2]}/${parts[n - 1]}"
  else
    OUT+="$shown"
  fi
}

main() {
  load_git_cache
  render_repo_dir
  render_git_seg
  # Matches Rust `println!("{out} ")`: trailing space then newline.
  printf '%s \n' "$OUT"
}

main "$@"
