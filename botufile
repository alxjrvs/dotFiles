# dotfile — this repo's config, read by `botu`. A short bash program of verb-aware
# declarations; `botu apply|verify|fix` source it under the matching verb.

section "Shell + git"
link .zshrc       ~/.zshrc
link .zprofile    ~/.zprofile
link .zshenv      ~/.zshenv
link .hushlogin   ~/.hushlogin
link .gitconfig   ~/.gitconfig
link .gitmessage  ~/.gitmessage
link .gitignore   ~/.gitignore
link .editorconfig ~/.editorconfig
link .ripgreprc   ~/.ripgreprc
link .fdignore    ~/.fdignore
link git-template/hooks/pre-commit ~/.config/git/template/hooks/pre-commit

section "SSH"
link --mode 600 ssh/config ~/.ssh/config
link ssh/1password-agent.toml ~/.config/1Password/ssh/agent.toml

section "Tools"
link mise.toml          ~/.config/mise/config.toml
link mise-settings.toml ~/.config/mise/conf.d/settings.toml
link sheldon/plugins.toml ~/.config/sheldon/plugins.toml
link starship.toml      ~/.config/starship.toml
link cmux/cmux.json     ~/.config/cmux/cmux.json
link ghostty/config     ~/.config/ghostty/config
link bat/config         ~/.config/bat/config
link atuin/config.toml  ~/.config/atuin/config.toml
link gh/config.yml      ~/.config/gh/config.yml
link nvim/init.lua      ~/.config/nvim/init.lua
link karabiner/karabiner.json ~/.config/karabiner/karabiner.json

section "Claude"
link dot-claude/CLAUDE.md     ~/.claude/CLAUDE.md
link dot-claude/settings.json ~/.claude/settings.json

section "zsh fragments"
glob 'zsh/[0-9]*.zsh' ~/.config/zsh/

# The launcher itself is a copy, not a symlink (survives a repo move) — but in
# the installed-dot universe this line goes away entirely: dot is on PATH.
# copy dot ~/.local/bin/dot

# Packages (the Brewfile / mise.toml ARE the data):
brewfile Brewfile
mise_install

# ── Imperative steps ──────────────────────────────────────────────────────────
# Small steps inline with `on <verb> CMD`; the botufile is bash, so they need no
# file. A hook file is only for substantial logic (claude, below) or a script an
# external program execs by path (op-agent, called by an MCP headersHelper).

section "SSH perms"
on apply chmod 700 ~/.ssh
on apply mkdir -p ~/.ssh/cm
on apply chmod 700 ~/.ssh/cm

section "lefthook"
on apply lefthook install

# (macOS defaults → restart Dock/Finder/SystemUIServer is built into botu now —
#  the engine does it automatically when any osx_default changed. Not a botufile
#  concern: it's the universal consequence of the osx_default primitive.)

# op-agent: one script, two surfaces. Linked onto PATH so MCP headersHelpers can
# call `op-agent header op://…` (replacing the gh/render shims), AND driven below
# as reconcile steps. One file, parameterized by argument — no script-per-service.
section "op-agent"
link hooks/op-agent.sh ~/.local/bin/op-agent
on apply  op-agent provision
on verify op-agent status

# claude_statusline stays a hook file — multi-step clone+install, file-worthy.
section "claude_statusline"
hook claude_statusline repo=github.com/alxjrvs/claude-statusline
