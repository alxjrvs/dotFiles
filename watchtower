#!/usr/bin/env bash
# watchtower — local "Watchtower"-style security audit of your 1Password items,
# built entirely on the `op` CLI. 1Password ships no `op watchtower` command;
# Watchtower is client-side analytics in the apps. But its inputs all live in
# the item JSON, so this reconstructs the panels from the CLI:
#
#   Breached   passwords found in Have-I-Been-Pwned. k-anonymity: only the first
#              5 chars of each SHA-1 hash are sent — never the password or the
#              full hash. Skip the network entirely with --no-breach.
#   Reused     the same password on 2+ items (compared by local hash).
#   Weak       1Password's own strength rating (TERRIBLE / WEAK / FAIR).
#   Unsecured  items whose URL is http:// (non-TLS).
#   2FA        how many logins have a TOTP stored. A floor, not Watchtower's full
#              "2FA available" check — that needs 1Password's site catalog, which
#              the CLI can't see.
#
# Dev creds are excluded from the warnings (a weak password on a LAN box is not
# a real risk): an item is treated as "dev/local" — listed separately, never
# flagged — when any URL is loopback/localhost, *.local (mDNS), or an RFC-1918
# private range, OR the item carries the `watchtower-ignore` tag (use that tag
# for URL-less dev creds you want permanently ignored).
#
# Privacy: passwords live only in shell vars and a 0700 temp dir that holds ONLY
# SHA-1/Base64 hashes; the dir is removed on exit. No plaintext secret is ever
# printed or persisted.
#
# Foreground only: the 1Password desktop-app integration authorizes `op` against
# the calling session, so a detached/backgrounded run gets denied after the first
# few items. Run it interactively (as `dot watchtower`).
#
# Flags:
#   --vault=NAME   audit only that vault (default: all vaults)
#   --no-breach    skip the Have-I-Been-Pwned lookup (fully offline)
#   -h, --help

set -euo pipefail

# ── Output helpers (match doctor's palette) ───────────────────────────────────
_hdr() { printf '\n\033[1m==> %s\033[0m\n' "$*"; }
_ok() { printf '\033[0;32m  \xe2\x9c\x93 %s\033[0m\n' "$*"; }
_warn() { printf '\033[0;33m  \xe2\x86\x92 %s\033[0m\n' "$*"; }
_crit() { printf '\033[0;31m  \xe2\x9c\x97 %s\033[0m\n' "$*"; }
_note() { printf '    %s\n' "$*"; }

# ── Flags ─────────────────────────────────────────────────────────────────────
_VAULT=""
_BREACH=1
for _arg in "$@"; do
  case "$_arg" in
    --vault=*) _VAULT="${_arg#--vault=}" ;;
    --no-breach) _BREACH=0 ;;
    -h | --help)
      printf 'usage: watchtower [--vault=NAME] [--no-breach]\n'
      printf '  Local Watchtower-style audit of 1Password via the op CLI.\n'
      printf '  --vault=NAME   audit only that vault (default: all)\n'
      printf '  --no-breach    skip the Have-I-Been-Pwned lookup (offline)\n'
      printf '  Dev creds (localhost/.local/LAN URLs, or the watchtower-ignore\n'
      printf '  tag) are listed separately and never flagged.\n'
      exit 0
      ;;
    *)
      printf 'watchtower: unknown argument: %s (try --help)\n' "$_arg" >&2
      exit 2
      ;;
  esac
done
unset _arg

# ── Prerequisites ─────────────────────────────────────────────────────────────
for _bin in op jq shasum awk; do
  command -v "$_bin" > /dev/null 2>&1 || {
    printf 'watchtower: required tool not found: %s\n' "$_bin" >&2
    exit 1
  }
done
unset _bin
if [[ "$_BREACH" -eq 1 ]] && ! command -v curl > /dev/null 2>&1; then
  _warn "curl not found — breach check disabled"
  _BREACH=0
fi

# ── Private scratch dir (hashes only), removed on exit ────────────────────────
_TMP=$(mktemp -d "${TMPDIR:-/tmp}/watchtower.XXXXXX")
chmod 700 "$_TMP"
cleanup() { rm -rf "$_TMP"; }
trap cleanup EXIT INT TERM
DATA="${_TMP}/data.tsv"
: > "$DATA"

# ── 1. Collect credential items (LOGIN + PASSWORD categories) ─────────────────
# One `op item get` per item; the password value never leaves this process —
# we keep only its SHA-1. `< /dev/null` keeps op from draining the loop's stdin.
_list_args=(--format=json)
[[ -n "$_VAULT" ]] && _list_args+=(--vault "$_VAULT")
op item list "${_list_args[@]}" 2> /dev/null |
  jq -r '.[] | select(.category=="LOGIN" or .category=="PASSWORD") | .id' > "${_TMP}/ids.txt" || true
_total=$(grep -c . "${_TMP}/ids.txt" || true)

_hdr "Watchtower${_VAULT:+ — vault: $_VAULT}"
printf '  scanning %s credential items (reading passwords locally)...\n' "$_total" >&2

# jq projection (TSV): vault, title, strength, entropy, has-TOTP, has-http-url,
# is-dev, base64(password). map(select(type=="string")) guards null/odd shapes.
# A "dev" item (loopback/.local/RFC-1918 URL, or the watchtower-ignore tag) is
# reported separately and excluded from every warning.
# shellcheck disable=SC2016  # $pw/$st/... are jq vars, not shell expansions
_JQ='
  ([.fields[]? | select(.purpose=="PASSWORD") | .value] | map(select(type=="string")) | .[0] // "") as $pw
  | ([.fields[]? | select(.purpose=="PASSWORD") | .password_details.strength] | .[0] // "NONE") as $st
  | ([.fields[]? | select(.purpose=="PASSWORD") | .password_details.entropy] | .[0] // 0) as $en
  | (any(.fields[]?; .type=="OTP")) as $otp
  | ([.urls[]?.href] | map(select(type=="string") | ascii_downcase)) as $urls
  | ($urls | any(startswith("http://"))) as $unsec
  | ($urls | any(test("^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|\\[::1\\]|[^/]*\\.local|10\\.|192\\.168\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)"))) as $localurl
  | (((.tags // []) | any(. == "watchtower-ignore")) or $localurl) as $dev
  | [ .vault.name, .title, $st, ($en|tostring), ($otp|tostring), ($unsec|tostring), ($dev|tostring),
      (if $pw=="" then "" else ($pw|@base64) end) ] | @tsv'

_n=0
while IFS= read -r _id; do
  [[ -z "$_id" ]] && continue
  _n=$((_n + 1))
  [[ $((_n % 50)) -eq 0 ]] && printf '  ...%s/%s\n' "$_n" "$_total" >&2
  _rec=$(op item get "$_id" --format json < /dev/null 2> /dev/null | jq -r "$_JQ" 2> /dev/null) || _rec=""
  [[ -z "$_rec" ]] && continue
  _pwb64=$(printf '%s' "$_rec" | cut -f8)
  if [[ -n "$_pwb64" ]]; then
    _sha1=$(printf '%s' "$_pwb64" | base64 -d 2> /dev/null | shasum -a 1 | awk '{print toupper($1)}')
  else
    _sha1=""
  fi
  # rewrite the row with the hash (col 8) replacing the base64 password
  printf '%s\t%s\n' "$(printf '%s' "$_rec" | cut -f1-7)" "$_sha1" >> "$DATA"
done < "${_TMP}/ids.txt"
unset _id _rec _pwb64 _sha1 _n

# Columns: 1 vault  2 title  3 strength  4 entropy  5 otp  6 unsec  7 dev  8 sha1
# Real (non-dev) rows drive every warning; $7=="true" is excluded.
_rows=$(grep -c . "$DATA" || true)
_dev_n=$(awk -F'\t' '$7=="true"' "$DATA" | wc -l | tr -d ' ')
_withpw=$(awk -F'\t' '$7!="true" && $8!=""' "$DATA" | wc -l | tr -d ' ')

# ── 2. Breached (Have-I-Been-Pwned, k-anonymity over unique non-dev hashes) ───
_BRK="${_TMP}/breach.tsv"
: > "$_BRK"
if [[ "$_BREACH" -eq 1 ]]; then
  printf '  checking Have-I-Been-Pwned...\n' >&2
  awk -F'\t' '$7!="true" && $8!=""{print $8}' "$DATA" | sort -u | while IFS= read -r _h; do
    [[ -z "$_h" ]] && continue
    _pre="${_h:0:5}"
    _suf="${_h:5}"
    # NB: no early `exit` in awk — exiting closes the pipe, curl takes SIGPIPE,
    # and under pipefail that non-zero status would clobber a real match to "".
    _cnt=$(curl -s --max-time 10 "https://api.pwnedpasswords.com/range/${_pre}" < /dev/null |
      tr -d '\r' | awk -F: -v s="$_suf" 'toupper($1)==s{print $2}') || _cnt=""
    if [[ -n "$_cnt" ]]; then
      printf '%s\t%s\n' "$_h" "$_cnt" >> "$_BRK"
    fi
  done || true
fi

# ── 3. Report ─────────────────────────────────────────────────────────────────
_hdr "Breached passwords (Have-I-Been-Pwned)"
if [[ "$_BREACH" -eq 0 ]]; then
  _note "(skipped — --no-breach)"
elif [[ -s "$_BRK" ]]; then
  while IFS=$'\t' read -r _h _cnt; do
    _crit "password in ${_cnt} known breaches:"
    awk -F'\t' -v H="$_h" '$7!="true" && $8==H{printf "    [%s] %s  (%s)\n",$1,$2,$3}' "$DATA"
  done < "$_BRK"
else
  _ok "none of your passwords appear in HiBP"
fi
unset _h _cnt

_hdr "Reused passwords (same password on 2+ items)"
_reused=$(awk -F'\t' '$7!="true" && $8!=""{print $8}' "$DATA" | sort | uniq -d)
if [[ -n "$_reused" ]]; then
  printf '%s\n' "$_reused" | while IFS= read -r _h; do
    [[ -z "$_h" ]] && continue
    _bk=$(awk -F'\t' -v H="$_h" '$1==H{printf " (BREACHED x%s)",$2}' "$_BRK")
    _warn "reused${_bk}:"
    awk -F'\t' -v H="$_h" '$7!="true" && $8==H{printf "    [%s] %s\n",$1,$2}' "$DATA"
  done
else
  _ok "no reused passwords"
fi
unset _reused _h _bk

_hdr "Weak passwords (1Password strength rating)"
_weak=$(awk -F'\t' '$7!="true" && ($3=="TERRIBLE" || $3=="WEAK")' "$DATA")
if [[ -n "$_weak" ]]; then
  printf '%s\n' "$_weak" | sort -t"$(printf '\t')" -k3 |
    awk -F'\t' '{printf "  \033[0;31m\xe2\x9c\x97\033[0m [%s] %s  (%s)\n",$1,$2,$3}'
else
  _ok "no TERRIBLE/WEAK passwords"
fi
_fair=$(awk -F'\t' '$7!="true" && $3=="FAIR"' "$DATA" | wc -l | tr -d ' ')
[[ "$_fair" -gt 0 ]] && _warn "${_fair} more rated FAIR (borderline) — run with a vault filter to list"
unset _weak _fair

_hdr "Unsecured (http://) websites"
_unsec=$(awk -F'\t' '$7!="true" && $6=="true"{printf "  [%s] %s\n",$1,$2}' "$DATA")
if [[ -n "$_unsec" ]]; then
  printf '%s\n' "$_unsec"
else
  _ok "no http:// URLs (excluding dev)"
fi
unset _unsec

if [[ "$_dev_n" -gt 0 ]]; then
  _hdr "Dev / local (excluded from warnings)"
  awk -F'\t' '$7=="true"{printf "    [%s] %s  (%s)\n",$1,$2,$3}' "$DATA" | sort
  _note "localhost/.local/LAN URL or watchtower-ignore tag — not a real-world risk"
fi

# ── 4. Summary ────────────────────────────────────────────────────────────────
_hdr "Summary"
_strong=$(awk -F'\t' '$7!="true" && ($3=="FANTASTIC" || $3=="EXCELLENT" || $3=="VERY_GOOD")' "$DATA" | wc -l | tr -d ' ')
_2fa=$(awk -F'\t' '$7!="true" && $5=="true"' "$DATA" | wc -l | tr -d ' ')
_brk_n=$(grep -c . "$_BRK" 2> /dev/null || true)
printf '  items scanned: %s   with password: %s   strong: %s   dev/excluded: %s\n' \
  "$_rows" "$_withpw" "$_strong" "$_dev_n"
printf '  2FA/TOTP stored: %s (floor, not full Watchtower 2FA-available check)\n' "$_2fa"
[[ "$_BREACH" -eq 1 ]] && printf '  breached: %s   ' "$_brk_n"
printf 'reused groups: %s\n' "$(awk -F'\t' '$7!="true" && $8!=""{print $8}' "$DATA" | sort | uniq -d | grep -c . || true)"
