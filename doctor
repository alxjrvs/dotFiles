#!/usr/bin/env bash
# doctor — read-only dotfiles health check.
# Exits non-zero when any hard failure is found.
#
# Honors DOTFILES_DOCTOR_SKIP_EXTERNAL=1 to skip slow/network-bound checks
# (brew bundle, gh auth, brew doctor, mise doctor, claude doctor).

set -euo pipefail

_DOCTOR_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# ── Inline helpers ────────────────────────────────────────────────────────────

# os_kind: returns "darwin" or "linux"
os_kind() {
  case "$(uname -s)" in
    Darwin) printf 'darwin\n' ;;
    Linux) printf 'linux\n' ;;
    *) printf 'unknown\n' ;;
  esac
}

# host_id: returns "air", "pro", or "unknown"
host_id() {
  local forced="${DOTFILES_HOST:-}"
  if [[ -n "$forced" ]]; then
    case "$(printf '%s' "$forced" | tr '[:upper:]' '[:lower:]')" in
      air)
        printf 'air\n'
        return 0
        ;;
      pro)
        printf 'pro\n'
        return 0
        ;;
    esac
  fi
  local hostname=""
  if command -v scutil > /dev/null 2>&1; then
    hostname=$(scutil --get LocalHostName 2> /dev/null || true)
  fi
  local lower
  lower=$(printf '%s' "$hostname" | tr '[:upper:]' '[:lower:]')
  if [[ "$lower" == *air* ]]; then
    printf 'air\n'
  elif [[ "$lower" == *pro* ]]; then
    printf 'pro\n'
  else
    printf 'unknown\n'
  fi
}

# resolve_dotfiles_dir: $DOTFILES_DIR → script parent → ~/dotFiles
resolve_dotfiles_dir() {
  local candidates=(
    "${DOTFILES_DIR:-}"
    "${_DOCTOR_DIR}"
    "${HOME}/dotFiles"
  )
  local c
  for c in "${candidates[@]}"; do
    [[ -n "$c" && -d "$c" && -f "${c}/Brewfile" ]] && printf '%s\n' "$c" && return 0
  done
  return 1
}

# ── Prepend mise shims to PATH ────────────────────────────────────────────────
_mise_shims="${HOME}/.local/share/mise/shims"
if [[ -d "$_mise_shims" ]]; then
  case ":${PATH}:" in
    *":${_mise_shims}:"*) ;;
    *) PATH="${_mise_shims}:${PATH}" ;;
  esac
fi
export PATH
unset _mise_shims

# ── Source macos module for audit function ────────────────────────────────────
# We only need macos_audit(); source with __DOT_SYNC_SOURCED set so the
# module skips re-sourcing helpers it doesn't need.
__DOT_SYNC_SOURCED=1
export __DOT_SYNC_SOURCED
# shellcheck source=install/90-macos.sh
source "${_DOCTOR_DIR}/install/90-macos.sh"

# ── Counters ──────────────────────────────────────────────────────────────────
_FAILS=0
_WARNS=0

_ok() { printf '\033[0;32m  \xe2\x9c\x93 %s\033[0m\n' "$*"; }
_warn() {
  printf '\033[0;33m  \xe2\x86\x92 %s\033[0m\n' "$*"
  _WARNS=$((_WARNS + 1))
}
_fail() {
  printf '\033[0;31m  \xe2\x9c\x97 %s\033[0m\n' "$*" >&2
  _FAILS=$((_FAILS + 1))
}

skip_external="${DOTFILES_DOCTOR_SKIP_EXTERNAL:-}"

printf '==> Doctor\n'

# ── 1. Git config ─────────────────────────────────────────────────────────────
_user_name=$(git config user.name 2> /dev/null || true)
_user_email=$(git config user.email 2> /dev/null || true)
if [[ -n "$_user_name" && -n "$_user_email" ]]; then
  _ok "git: ${_user_name} <${_user_email}>"
else
  _fail "git: missing user.name or user.email"
fi
unset _user_name _user_email

# ── 2. Tool presence ──────────────────────────────────────────────────────────
# "dot" replaces "dotctl" in the tool list.
_tools=(dot git gh mise)
if [[ "$(os_kind)" == "darwin" ]]; then
  _tools+=(brew node bun sheldon lefthook nvim)
fi

for _tool in "${_tools[@]}"; do
  # Presence is what this check is for — probe the binary on PATH, not its
  # --version output. gh in particular loads ~/.config/gh/hosts.yml at startup
  # and exits non-zero when that file is unreadable — whether from broken perms
  # (e.g. a root-owned 000 hosts.yml) or, for a sandboxed caller, the denyRead
  # rule on that path. gh itself is in sandbox.excludedCommands, so a top-level
  # gh runs unsandboxed; the failure this guards against is a config-read error,
  # not the sandbox per se. Use `--version` only for the friendly version
  # string, never as the presence test.
  if ! command -v "$_tool" > /dev/null 2>&1; then
    _fail "${_tool}: not found"
    continue
  fi
  _ver=$("$_tool" --version 2> /dev/null | head -1 || true)
  if [[ -n "$_ver" ]]; then
    _ok "${_tool}: ${_ver}"
  else
    _ok "${_tool}: present (version unavailable — config unreadable)"
  fi
done
unset _tools _tool _ver

# ── 3. Symlink integrity ──────────────────────────────────────────────────────
_dotfiles=$(resolve_dotfiles_dir 2> /dev/null || true)
if [[ -z "$_dotfiles" ]]; then
  _warn "dotfiles repo not found (\$DOTFILES_DIR / dot target / ~/dotFiles) — symlink + drift audits will be skipped"
else
  # Expected symlink pairs: "link_rel|target_rel".
  # Kept 1:1 in sync with install/40-symlinks.sh. The zsh/[0-9]*.zsh fragment
  # glob is handled below the static list. Pairs whose source is absent are
  # skipped silently (see loop).
  _expected_links=(
    ".zshrc|.zshrc"
    ".zprofile|.zprofile"
    ".zshenv|.zshenv"
    ".hushlogin|.hushlogin"
    ".gitconfig|.gitconfig"
    ".gitmessage|.gitmessage"
    ".gitignore|.gitignore"
    ".ripgreprc|.ripgreprc"
    ".fdignore|.fdignore"
    ".editorconfig|.editorconfig"
    ".local/bin/dot|dot"
    ".config/git/template/hooks/pre-commit|git-template/hooks/pre-commit"
    ".claude/CLAUDE.md|dot-claude/CLAUDE.md"
    ".claude/settings.json|dot-claude/settings.json"
    ".config/sheldon/plugins.toml|sheldon/plugins.toml"
    ".config/mise/config.toml|mise.toml"
    ".config/gh/config.yml|gh/config.yml"
    ".local/bin/gh-mcp-auth-header|gh/gh-mcp-auth-header"
    ".config/ghostty/config|ghostty/config"
    ".config/bat/config|bat/config"
    ".config/atuin/config.toml|atuin/config.toml"
    ".config/lazygit/config.yml|lazygit/config.yml"
    ".config/nvim/init.lua|nvim/init.lua"
    ".config/karabiner/karabiner.json|karabiner/karabiner.json"
    ".ssh/config|ssh/config"
    ".config/1Password/ssh/agent.toml|ssh/1password-agent.toml"
    ".local/bin/git-ssh-sign|ssh/git-ssh-sign"
  )

  # zsh fragments are a glob in install/40-symlinks.sh — expand the same
  # [0-9]*.zsh set into the expected-link list so each fragment is audited.
  if [[ -d "${_dotfiles}/zsh" ]]; then
    for _zfrag in "${_dotfiles}"/zsh/[0-9]*.zsh; do
      [[ -f "$_zfrag" ]] || continue
      _zname=$(basename "$_zfrag")
      _expected_links+=(".config/zsh/${_zname}|zsh/${_zname}")
    done
    unset _zfrag _zname
  fi

  _checked=0
  for _pair in "${_expected_links[@]}"; do
    IFS='|' read -r _link_rel _target_rel <<< "$_pair"
    local_link="${HOME}/${_link_rel}"
    expected_target="${_dotfiles}/${_target_rel}"

    # An absent source means the expected-links table drifted from the repo
    # (a dropped tool whose row wasn't removed) — surface it, don't hide it.
    if [[ ! -e "$expected_target" && ! -L "$expected_target" ]]; then
      _warn "expected-links table lists ${_target_rel} but the repo has no such file — remove the stale row"
      continue
    fi

    _checked=$((_checked + 1))
    if [[ ! -e "$local_link" && ! -L "$local_link" ]]; then
      _warn "symlink missing: ${local_link} (expected -> ${expected_target})"
    elif [[ ! -L "$local_link" ]]; then
      _warn "${local_link} is not a symlink (expected -> ${expected_target})"
    else
      _actual_target=$(readlink "$local_link" 2> /dev/null || true)
      if [[ "$_actual_target" == "$expected_target" ]]; then
        : # silently pass
      else
        _warn "${local_link} points to ${_actual_target}, expected ${expected_target}"
      fi
    fi
  done
  _ok "symlinks: ${_checked} checked"
  unset _expected_links _pair _link_rel _target_rel _checked _actual_target local_link expected_target

  # ── 4. brew bundle drift (Darwin, external) ───────────────────────────────
  if [[ "$(os_kind)" == "darwin" && -z "$skip_external" ]]; then
    _brewfile="${_dotfiles}/Brewfile"
    if [[ -f "$_brewfile" ]]; then
      if brew bundle check --no-upgrade --file="$_brewfile" \
        > /dev/null 2>&1; then
        _ok "brew bundle: all dependencies satisfied"
      else
        _warn "brew bundle: drift — run \`brew bundle --file=${_brewfile}\`"
      fi
    fi
    unset _brewfile
  fi
fi
unset _dotfiles

# ── 5. gh auth status (external) ─────────────────────────────────────────────
if [[ -z "$skip_external" ]]; then
  if gh auth status > /dev/null 2>&1; then
    _ok "gh: authenticated"
  else
    _warn "gh: not authenticated — run \`gh auth login\`"
  fi
fi

# ── 6. mise tools installed ───────────────────────────────────────────────────
if _mise_missing=$(mise ls --missing 2> /dev/null); then
  _missing_count=$(printf '%s\n' "$_mise_missing" | grep -c '\S' || true)
  if [[ "$_missing_count" -eq 0 ]]; then
    _ok "mise: all declared tools installed"
  else
    _warn "mise: ${_missing_count} tool(s) missing — run \`mise install\`"
    printf '%s\n' "$_mise_missing" | head -5 | while IFS= read -r _ml; do
      printf '\033[0;33m  \xe2\x86\x92   %s\033[0m\n' "$_ml"
      _WARNS=$((_WARNS + 1))
    done
  fi
fi
unset _mise_missing _missing_count

# ── 7. lefthook hook installed ────────────────────────────────────────────────
_dotfiles2=$(resolve_dotfiles_dir 2> /dev/null || true)
if [[ -n "$_dotfiles2" ]]; then
  _lh_hook="${_dotfiles2}/.git/hooks/pre-commit"
  if [[ ! -f "$_lh_hook" ]]; then
    _warn "lefthook: pre-commit hook not installed in dotfiles repo — run \`lefthook install\`"
  else
    if grep -qF "lefthook" "$_lh_hook" 2> /dev/null; then
      _ok "lefthook: pre-commit hook installed"
    else
      _warn "lefthook: pre-commit hook present but not authored by lefthook — run \`lefthook install\`"
    fi
  fi
  unset _lh_hook
fi
unset _dotfiles2

# ── 8. pueued daemon liveness ─────────────────────────────────────────────────
if pueued --version > /dev/null 2>&1; then
  if pueue status > /dev/null 2>&1; then
    _ok "pueued: daemon responding"
  else
    _warn "pueued: daemon not running — start with \`pueued -d\`"
  fi
fi

# ── 9. brew doctor (Darwin, external) ─────────────────────────────────────────
if [[ "$(os_kind)" == "darwin" && -z "$skip_external" ]]; then
  _brew_out=$(brew doctor 2>&1 || true)
  if printf '%s\n' "$_brew_out" | grep -q "ready to brew"; then
    _ok "brew doctor: ready to brew"
  else
    _brew_warns=$(printf '%s\n' "$_brew_out" | grep -c '^\s*Warning:' || true)
    _brew_warns=$((_brew_warns > 0 ? _brew_warns : 1))
    _warn "brew doctor: ${_brew_warns} warning(s) — run \`brew doctor\` for details"
    printf '%s\n' "$_brew_out" | grep '^\s*Warning:' | head -3 | while IFS= read -r _wl; do
      printf '\033[0;33m  \xe2\x86\x92   %s\033[0m\n' "${_wl## }"
    done
    # Counter already bumped by _warn above; add extra for multi-warning.
    if [[ "$_brew_warns" -gt 1 ]]; then
      _WARNS=$((_WARNS + _brew_warns - 1))
    fi
  fi
  unset _brew_out _brew_warns
fi

# ── 10. mise doctor (external) ───────────────────────────────────────────────
if [[ -z "$skip_external" ]]; then
  # Strip shims from PATH for this one call so mise doesn't complain about
  # "mise tool paths are not first in PATH" (the shims are first because WE
  # put them there; the user's interactive shell has them via .zshenv).
  _saved_path="$PATH"
  _shims_prefix="${HOME}/.local/share/mise/shims:"
  _stripped_path="${PATH#"$_shims_prefix"}"
  export PATH="$_stripped_path"

  _mise_out=$(mise doctor 2>&1 || true)

  export PATH="$_saved_path"
  unset _saved_path _shims_prefix _stripped_path

  # Parse "N warning(s) found:" from mise output.
  _mise_warns=0
  while IFS= read -r _ml; do
    _trimmed="${_ml## }"
    _trimmed="${_trimmed%% }"
    if [[ "$_trimmed" == *"warning found:"* || "$_trimmed" == *"warnings found:"* ]]; then
      _n="${_trimmed%% warning*}"
      _n="${_n## }"
      if [[ "$_n" =~ ^[0-9]+$ ]]; then
        _mise_warns="$_n"
      fi
    fi
  done <<< "$_mise_out"

  if [[ "$_mise_warns" -eq 0 ]] && printf '%s\n' "$_mise_out" | grep -q "No problems found"; then
    _ok "mise doctor: no problems found"
  elif [[ "$_mise_warns" -gt 0 ]]; then
    _warn "mise doctor: ${_mise_warns} warning(s) — run \`mise doctor\` for details"
    # _warn already bumped _WARNS once; add extra for multi-warning.
    if [[ "$_mise_warns" -gt 1 ]]; then
      _WARNS=$((_WARNS + _mise_warns - 1))
    fi
  else
    _warn "mise doctor: output unparseable — run \`mise doctor\` manually"
  fi
  unset _mise_out _mise_warns _ml _trimmed _n
fi

# ── 11. claude doctor (external) ─────────────────────────────────────────────
if [[ -z "$skip_external" ]]; then
  _claude_ver=$(claude --version 2> /dev/null | head -1 || true)
  if [[ -n "$_claude_ver" ]]; then
    if _claude_out=$(claude doctor 2>&1); then
      _ok "claude doctor: healthy"
    else
      _fail "claude doctor: failed — output below"
      printf '%s\n' "$_claude_out" | head -20 | while IFS= read -r _cl; do
        printf '  %s\n' "$_cl" >&2
      done
    fi
    unset _claude_out _cl
  fi
  unset _claude_ver
fi

# ── 12. macOS defaults drift (Darwin) ────────────────────────────────────────
if [[ "$(os_kind)" == "darwin" ]]; then
  _matches=0 _drifted=0 _missing=0
  while IFS= read -r _audit_line; do
    IFS='|' read -r _result _domain _key _expected _actual <<< "${_audit_line}|||"
    case "$_result" in
      match)
        _matches=$((_matches + 1))
        ;;
      drift)
        printf '\033[0;33m  \xe2\x86\x92 macos: %s.%s = %s (expected %s)\033[0m\n' \
          "$_domain" "$_key" "$_actual" "$_expected"
        _drifted=$((_drifted + 1))
        _WARNS=$((_WARNS + 1))
        ;;
      missing)
        # shellcheck disable=SC2016  # backticks are literal text in the message
        printf '\033[0;33m  \xe2\x86\x92 macos: %s.%s unset (run `dot sync --only=macos`)\033[0m\n' \
          "$_domain" "$_key"
        _missing=$((_missing + 1))
        _WARNS=$((_WARNS + 1))
        ;;
    esac
  done < <(macos_audit)
  _ok "macos defaults: ${_matches} matched, ${_drifted} drifted, ${_missing} missing"
  unset _matches _drifted _missing _audit_line _result _domain _key _expected _actual
fi

# ── 13. SSH signing chain ────────────────────────────────────────────────────
printf '\n==> SSH signing\n'

_op_sock="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
if [[ -S "$_op_sock" ]]; then
  _ok "1Password agent socket present (auth)"
else
  _warn "1Password agent socket missing — enable Settings -> Developer -> SSH agent"
fi
unset _op_sock

_sign_sock="${HOME}/.ssh/agent/signing.sock"
_sign_key="${HOME}/.ssh/id_ed25519"
if [[ -S "$_sign_sock" ]] && SSH_AUTH_SOCK="$_sign_sock" ssh-add -l > /dev/null 2>&1; then
  _sign_fp=$(ssh-keygen -lf "${_sign_key}.pub" 2> /dev/null | awk '{print $2}')
  if [[ -n "$_sign_fp" ]] && SSH_AUTH_SOCK="$_sign_sock" ssh-add -l 2> /dev/null | grep -qF "$_sign_fp"; then
    _ok "signing agent up with key loaded"
  else
    _warn "signing agent up but signing key not loaded — run: dot sync --only=ssh"
  fi
else
  _warn "signing agent unreachable at ~/.ssh/agent/signing.sock — run: dot sync --only=ssh"
fi
unset _sign_sock _sign_fp

_eff_key=$(git config user.signingkey 2> /dev/null || true)
_pub_line=$(cat "${_sign_key}.pub" 2> /dev/null || true)
if [[ -n "$_pub_line" && "$_eff_key" == "key::${_pub_line}" ]]; then
  _ok "user.signingkey matches this machine's pubkey"
else
  _warn "user.signingkey does not match ~/.ssh/id_ed25519.pub — run: dot sync --only=ssh"
fi
if [[ -n "$_pub_line" ]] && grep -qF "$_pub_line" "${HOME}/.ssh/allowed_signers" 2> /dev/null; then
  _ok "pubkey present in allowed_signers"
else
  _warn "pubkey missing from ~/.ssh/allowed_signers — run: dot sync --only=ssh"
fi
unset _eff_key _pub_line _sign_key

# Dead-rule lint: seatbelt subpath matching is LITERAL — a glob in
# allowUnixSockets never matches anything (root cause of the 2026-06-05
# sandboxed-signing failure; regression guard).
_dotfiles=$(resolve_dotfiles_dir 2> /dev/null || true)
if [[ -n "$_dotfiles" ]] && command -v jq > /dev/null 2>&1; then
  if jq -r '.sandbox.network.allowUnixSockets[]?' "${_dotfiles}/dot-claude/settings.json" 2> /dev/null | grep -q '\*'; then
    _warn "allowUnixSockets contains a glob — seatbelt subpath is literal; that rule is dead"
  else
    _ok "allowUnixSockets entries are literal"
  fi
fi
unset _dotfiles

if [[ -e "${HOME}/.augment/ssh-config" ]]; then
  _ok "\$HOME/.augment/ssh-config include target present"
else
  _warn "\$HOME/.augment/ssh-config missing (ssh/config Include target; externally managed)"
fi

# ── 14. Claude permission scopes ──────────────────────────────────────────────
# The tracked policy lives in dot-claude/settings.json; permission arrays merge
# across scopes, so an allow added to a project/local scope can quietly defeat
# a tracked ask/deny gate. Audit the live scope files against the tracked
# rules. Read-only; jq-gated like the other settings checks.
printf '\n==> Claude permission scopes\n'
_dotfiles=$(resolve_dotfiles_dir 2> /dev/null || true)
if [[ -n "$_dotfiles" ]] && command -v jq > /dev/null 2>&1; then
  _tracked="${_dotfiles}/dot-claude/settings.json"

  # This repo's policy: no settings.local.json overlay at all.
  if [[ -e "${_dotfiles}/.claude/settings.local.json" ]]; then
    _warn ".claude/settings.local.json exists — repo policy is no local overlay; fold deliberate grants into .claude/settings.json and rm it"
  else
    _ok "no .claude/settings.local.json overlay"
  fi

  # Collect allow rules from every live scope (the user scope is the tracked
  # file via symlink — including it also catches self-inconsistency).
  _scope_allows=$(
    for _sf in "${HOME}/.claude/settings.json" \
      "${_dotfiles}/.claude/settings.json" \
      "${_dotfiles}/.claude/settings.local.json"; do
      [[ -f "$_sf" ]] && jq -r '.permissions.allow[]?' "$_sf" 2> /dev/null
    done | sort -u
  )

  _gate_hits=0
  while IFS= read -r _rule; do
    [[ -n "$_rule" ]] || continue
    # Shell-wrapper allows smuggle any denied/asked command through a fresh
    # shell — they defeat every Bash gate at once.
    case "$_rule" in
      "Bash(bash *)" | "Bash(sh *)" | "Bash(zsh *)" | "Bash(env *)" | "Bash(eval *)")
        _warn "scope allow '$_rule' is a shell wrapper — it defeats every tracked Bash ask/deny gate"
        _gate_hits=$((_gate_hits + 1))
        continue
        ;;
    esac
    # An allow that duplicates a tracked ask/deny rule string overrides the
    # gate in the merged policy.
    if jq -e --arg r "$_rule" \
      '(.permissions.ask + .permissions.deny) | index($r)' \
      "$_tracked" > /dev/null 2>&1; then
      _warn "scope allow '$_rule' duplicates a tracked ask/deny rule — the gate is defeated"
      _gate_hits=$((_gate_hits + 1))
    fi
  done <<< "$_scope_allows"
  if [[ "$_gate_hits" -eq 0 ]]; then
    _ok "no scope allow defeats a tracked ask/deny gate"
  fi
  unset _tracked _scope_allows _gate_hits _rule _sf
else
  _warn "claude scope audit skipped (no dotfiles dir or jq)"
fi
unset _dotfiles

# ── Summary ───────────────────────────────────────────────────────────────────
printf '\n'
if [[ "$_FAILS" -eq 0 && "$_WARNS" -eq 0 ]]; then
  _ok "All checks passed"
elif [[ "$_FAILS" -eq 0 ]]; then
  printf '\033[0;33m  \xe2\x86\x92 %d warning(s) — see above\033[0m\n' "$_WARNS"
else
  printf '\033[0;31m  \xe2\x9c\x97 %d error(s), %d warning(s)\033[0m\n' "$_FAILS" "$_WARNS" >&2
  exit 1
fi
