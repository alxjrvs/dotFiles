#!/usr/bin/env bash
# doctor — dotfiles health check. Read-only by default.
#
# Exit codes (so callers — CI, bootstrap, cron — can act on the result):
#   0   clean: no failures, no warnings
#   1   one or more hard failures
#   2   warnings only (degraded but not broken: symlink drift, brew/mise drift,
#       unconfigured signing, …). Distinct from 0 so "clean" is machine-checkable.
#
# Flags:
#   --fix   Repair the symlink contract — doctor's only mutation. Two parts:
#             1. reap orphaned symlinks (dangling links into the repo whose
#                source was deleted; the one repair sync's link() never does);
#             2. relink any contract path that's missing, a non-symlink file,
#                or pointing at the wrong target, via the same link() sync uses
#                (overwrite: rm + relink, no backup — canonical content is here).
#           Non-symlink drift (brew/mise/macos) keeps its read-only
#           "run dot sync --only=X" hint.
#   --full  Also run a full-history secret scan (gitleaks detect) over the
#           dotfiles repo. Off by default because it's slow; the pre-commit
#           hook already guards new commits.
#
# Honors DOTFILES_DOCTOR_SKIP_EXTERNAL=1 to skip slow/network-bound checks
# (brew bundle drift, gh auth).

set -euo pipefail

_DOCTOR_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# ── Shared helpers (os_kind, resolve_dotfiles_dir) ────────────────────────────
# shellcheck source=lib/common.sh
_DOTFILES_SELF_DIR="$_DOCTOR_DIR"
source "${_DOCTOR_DIR}/lib/common.sh"

# ── Prepend mise shims to PATH ────────────────────────────────────────────────
_mise_shims="${HOME}/.local/share/mise/shims"
if [[ -d "$_mise_shims" ]]; then
  case ":${PATH}:" in
    *":${_mise_shims}:"*) ;;
    *) PATH="${_mise_shims}:${PATH}" ;;
  esac
fi
export PATH
unset _mise_shims

# ── Source modules for their reusable functions ───────────────────────────────
# doctor reuses macos_audit() (90-macos) and _symlink_pairs() (40-symlinks).
# lib/common.sh (sourced above) already defines the shared helpers they expect.
# shellcheck source=install/90-macos.sh
source "${_DOCTOR_DIR}/install/90-macos.sh"
# shellcheck source=install/40-symlinks.sh
source "${_DOCTOR_DIR}/install/40-symlinks.sh"

# ── Flags ─────────────────────────────────────────────────────────────────────
_FIX=0
_FULL=0
for _arg in "$@"; do
  case "$_arg" in
    --fix) _FIX=1 ;;
    --full) _FULL=1 ;;
    -h | --help)
      printf 'usage: doctor [--fix] [--full]\n'
      printf '  --fix    repair symlinks: reap orphans + relink missing/incorrect (default: read-only)\n'
      printf '  --full   also run a full-history gitleaks scan of the repo (slow)\n'
      printf '  exit codes: 0 clean, 1 failures, 2 warnings only\n'
      exit 0
      ;;
    *)
      printf 'doctor: unknown argument: %s (try --help)\n' "$_arg" >&2
      exit 2
      ;;
  esac
done
unset _arg

# ── Counters ──────────────────────────────────────────────────────────────────
_FAILS=0
_WARNS=0
_FIXED=0

# Output: _ok is the shared pure printer (from lib/common.sh). _warn/_fail/_fixed
# wrap the shared raw printers (_p_*) to also tally the counters that drive the
# exit code — so the ANSI strings still live in exactly one place (lib/common.sh).
_warn() {
  _p_warn "$*"
  _WARNS=$((_WARNS + 1))
}
_fail() {
  _p_fail "$*"
  _FAILS=$((_FAILS + 1))
}
# _fixed — a mutation doctor performed under --fix (cyan wrench).
_fixed() {
  _p_fixed "$*"
  _FIXED=$((_FIXED + 1))
}

# _vge HAVE MIN — true when version HAVE is >= MIN. Uses `sort -V` (version
# sort) so there's no hand-rolled dotted-number math: if MIN sorts first or
# ties, HAVE is at or above the floor.
_vge() {
  [[ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -1)" == "$2" ]]
}

skip_external="${DOTFILES_DOCTOR_SKIP_EXTERNAL:-}"

printf '==> Doctor\n'

# ── 1. Git config ─────────────────────────────────────────────────────────────
_user_name=$(git config user.name 2> /dev/null || true)
_user_email=$(git config user.email 2> /dev/null || true)
if [[ -n "$_user_name" && -n "$_user_email" ]]; then
  _ok "git: ${_user_name} <${_user_email}>"
else
  _fail "git: missing user.name or user.email"
fi
unset _user_name _user_email

# ── 2. Tool presence ──────────────────────────────────────────────────────────
_tools=(dot git gh mise)
if [[ "$(os_kind)" == "darwin" ]]; then
  _tools+=(brew node bun sheldon lefthook nvim)
fi

# Documented, load-bearing minimum version for a tool, or empty if it has none.
# Below the floor is a hard failure, not cosmetic:
#   brew < 6.0.0 — newer Brewfile/bundle conventions assumed by this repo
#   nvim < 0.11  — nvim/init.lua uses vim.lsp.config/enable (native LSP)
# A case function (not a `declare -A` map) so this script runs on macOS's stock
# bash 3.2.
_min_version() {
  case "$1" in
    brew) printf '6.0.0' ;;
    nvim) printf '0.11' ;;
  esac
}

for _tool in "${_tools[@]}"; do
  # Presence is what this check is for — probe the binary on PATH, not its
  # --version output. gh in particular loads ~/.config/gh/hosts.yml at startup
  # and exits non-zero when that file is unreadable (e.g. a root-owned 000
  # hosts.yml) — a config-read error, not a missing binary. Use `--version`
  # only for the friendly version string, never as the presence test.
  if ! command -v "$_tool" > /dev/null 2>&1; then
    _fail "${_tool}: not found"
    continue
  fi
  _ver=$("$_tool" --version 2> /dev/null | head -1 || true)
  _floor=$(_min_version "$_tool")
  if [[ -n "$_floor" ]]; then
    # Assert the documented minimum. Pull the first dotted-number run out of
    # the --version line (e.g. "Homebrew 6.0.0", "NVIM v0.11.2", "GNU bash,
    # version 5.2.21(1)...") and compare against the floor.
    if [[ "$_ver" =~ ([0-9]+(\.[0-9]+)*) ]]; then
      if _vge "${BASH_REMATCH[1]}" "$_floor"; then
        _ok "${_tool}: ${_ver}"
      else
        _fail "${_tool}: ${_ver} — below required ${_floor}"
      fi
    else
      _warn "${_tool}: ${_ver} (version unparseable — skipped ${_floor}+ check)"
    fi
  elif [[ -n "$_ver" ]]; then
    _ok "${_tool}: ${_ver}"
  else
    _ok "${_tool}: present (version unavailable — config unreadable)"
  fi
done
unset _tools _tool _ver _floor

# ── 3. Symlink integrity ──────────────────────────────────────────────────────
_dotfiles=$(resolve_dotfiles_dir 2> /dev/null || true)
if [[ -z "$_dotfiles" ]]; then
  _warn "dotfiles repo not found (\$DOTFILES_DIR / dot target / ~/dotFiles) — symlink + drift audits will be skipped"
else
  # Audit the exact pairs install/40-symlinks.sh applies — _symlink_pairs (from
  # the module sourced above) is the single source of truth, so this can't drift.
  _checked=0
  while IFS='|' read -r _src _dst; do
    [[ -n "$_src" ]] || continue
    local_link="${HOME}/${_dst}"
    expected_target="${_dotfiles}/${_src}"
    _checked=$((_checked + 1))
    _drift=""
    if [[ ! -e "$local_link" && ! -L "$local_link" ]]; then
      _drift="symlink missing: ${local_link} (expected -> ${expected_target})"
    elif [[ ! -L "$local_link" ]]; then
      _drift="${local_link} is not a symlink (expected -> ${expected_target})"
    else
      _actual_target=$(readlink "$local_link" 2> /dev/null || true)
      [[ "$_actual_target" == "$expected_target" ]] ||
        _drift="${local_link} points to ${_actual_target}, expected ${expected_target}"
    fi
    if [[ -n "$_drift" ]]; then
      if [[ "$_FIX" -eq 1 ]]; then
        # Repair with the same link() sync uses (overwrite = rm + relink, no
        # backup; canonical content is in the repo). Fixes all three cases:
        # missing -> create, wrong-type file -> replace, wrong target -> repoint.
        LINK_MODE=overwrite link "$expected_target" "$local_link"
        _FIXED=$((_FIXED + 1))
      else
        _warn "${_drift} (run: dot doctor --fix)"
      fi
    fi
  done < <(DOTFILES_DIR="$_dotfiles" _symlink_pairs)
  _ok "symlinks: ${_checked} checked"
  unset _checked _actual_target local_link expected_target _src _dst _drift

  # The dot launcher is a copy, not a symlink (so it survives a repo move). Verify
  # it's present, a current copy (not stale, not a dangling legacy symlink), and
  # that the breadcrumb sync records still points back to this repo. Repaired by
  # `dot sync`, not --fix: --fix only touches the symlink contract, and this is
  # outside it. Empty breadcrumb on a fresh machine pre-first-sync is expected.
  _bin="${HOME}/.local/bin/dot"
  _crumb="${XDG_STATE_HOME:-${HOME}/.local/state}/dot/dir"
  if [[ -L "$_bin" ]]; then
    _warn "dot launcher is a symlink — it will dangle if the repo moves (run: dot sync to convert to a copy)"
  elif [[ ! -f "$_bin" ]]; then
    _warn "dot launcher missing: ${_bin} (run: dot sync)"
  elif ! cmp -s "${_dotfiles}/dot" "$_bin" 2> /dev/null; then
    _warn "dot launcher stale vs ${_dotfiles}/dot (run: dot sync)"
  else
    _ok "dot launcher current (${_bin}, copy)"
  fi
  if [[ "$(cat "$_crumb" 2> /dev/null)" != "$_dotfiles" ]]; then
    _warn "dot breadcrumb ${_crumb} does not point at ${_dotfiles} (run: dot sync)"
  fi
  unset _bin _crumb

  # Orphaned symlinks (home→repo direction). The check above verifies every
  # contract entry is linked; this catches the reverse — a symlink in a managed
  # directory that points into the repo but whose source was deleted (e.g. a
  # removed zsh fragment). link() never reaps these, so they dangle silently.
  _orphans=0
  _expected=$(while IFS='|' read -r _s _d; do
    [[ -n "$_d" ]] && printf '%s\n' "${HOME}/${_d}"
  done < <(DOTFILES_DIR="$_dotfiles" _symlink_pairs))
  while IFS= read -r _mandir; do
    [[ -d "$_mandir" ]] || continue
    while IFS= read -r -d '' _link; do
      _tgt=$(readlink "$_link" 2> /dev/null || true)
      [[ "$_tgt" == "${_dotfiles}/"* ]] || continue # only repo-created links
      [[ -e "$_tgt" ]] && continue                  # source still present → fine
      if printf '%s\n' "$_expected" | grep -qxF "$_link"; then continue; fi
      if [[ "$_FIX" -eq 1 ]]; then
        rm -f "$_link" && _fixed "removed orphaned symlink: ${_link} -> ${_tgt}"
      else
        _warn "orphaned symlink: ${_link} -> ${_tgt} (source removed from repo; rm, or run: dot doctor --fix)"
        _orphans=$((_orphans + 1))
      fi
    done < <(find "$_mandir" -maxdepth 1 -type l -print0 2> /dev/null)
  done < <(while IFS='|' read -r _s _d; do
    [[ -n "$_d" ]] && dirname "${HOME}/${_d}"
  done < <(DOTFILES_DIR="$_dotfiles" _symlink_pairs) | sort -u)
  [[ "$_orphans" -eq 0 ]] && _ok "no orphaned symlinks"
  unset _orphans _expected _mandir _link _tgt _s _d

  # ── 4. brew bundle drift (Darwin, external) ───────────────────────────────
  if [[ "$(os_kind)" == "darwin" && -z "$skip_external" ]]; then
    _brewfile="${_dotfiles}/Brewfile"
    if [[ -f "$_brewfile" ]]; then
      if brew bundle check --no-upgrade --file="$_brewfile" \
        > /dev/null 2>&1; then
        _ok "brew bundle: all dependencies satisfied"
      else
        _warn "brew bundle: drift — run \`brew bundle --file=${_brewfile}\`"
      fi
    fi
    unset _brewfile
  fi
fi
# NB: _dotfiles is resolved once (above) and reused through §7 — don't unset here.

# ── 5. gh auth status (external) ─────────────────────────────────────────────
if [[ -z "$skip_external" ]]; then
  if gh auth status > /dev/null 2>&1; then
    _ok "gh: authenticated"
  else
    _warn "gh: not authenticated — run \`gh auth login\`"
  fi
fi

# ── 6. mise tools installed ───────────────────────────────────────────────────
if _mise_missing=$(mise ls --missing 2> /dev/null); then
  _missing_count=$(printf '%s\n' "$_mise_missing" | grep -c '\S' || true)
  if [[ "$_missing_count" -eq 0 ]]; then
    _ok "mise: all declared tools installed"
  else
    _warn "mise: ${_missing_count} tool(s) missing — run \`mise install\`"
    printf '%s\n' "$_mise_missing" | head -5 | while IFS= read -r _ml; do
      printf '\033[0;33m  \xe2\x86\x92   %s\033[0m\n' "$_ml"
      _WARNS=$((_WARNS + 1))
    done
  fi
fi
unset _mise_missing _missing_count

# ── 7. lefthook hook installed ────────────────────────────────────────────────
# Reuses _dotfiles resolved in §3 (single resolution across §3–§7).
if [[ -n "$_dotfiles" ]]; then
  _lh_hook="${_dotfiles}/.git/hooks/pre-commit"
  if [[ ! -f "$_lh_hook" ]]; then
    _warn "lefthook: pre-commit hook not installed in dotfiles repo — run \`lefthook install\`"
  else
    if grep -qF "lefthook" "$_lh_hook" 2> /dev/null; then
      _ok "lefthook: pre-commit hook installed"
    else
      _warn "lefthook: pre-commit hook present but not authored by lefthook — run \`lefthook install\`"
    fi
  fi
  unset _lh_hook
fi

# ── 7b. Full-history secret scan (opt-in, --full) ─────────────────────────────
# The pre-commit hook guards new commits; this catches anything already in
# history. Slow, so it only runs on demand.
if [[ "$_FULL" -eq 1 ]]; then
  if [[ -z "$_dotfiles" ]]; then
    _warn "gitleaks --full: dotfiles repo not found — skipping"
  elif ! command -v gitleaks > /dev/null 2>&1; then
    _warn "gitleaks --full: gitleaks not on PATH — run \`dot sync --only=mise\`"
  elif gitleaks detect --source "$_dotfiles" --redact --no-banner > /dev/null 2>&1; then
    _ok "gitleaks: full-history scan clean"
  else
    _fail "gitleaks: full-history scan found leaks — run \`gitleaks detect --source ${_dotfiles} -v\`"
  fi
fi
unset _dotfiles

# ── 8. Claude statusline (separate repo, installed to ~/.local/bin) ──────────
if [[ -L "${HOME}/.local/bin/claude-statusline" && -L "${HOME}/.local/bin/claude-subagent-statusline" ]]; then
  _ok "claude-statusline installed (~/.local/bin)"
else
  _warn "claude-statusline not installed — run: dot sync --only=claude"
fi

# Stock-tool health is the stock tools' job: run `brew doctor` / `mise doctor`
# / `claude doctor` directly.

# ── 9. macOS defaults drift (Darwin) ─────────────────────────────────────────
if [[ "$(os_kind)" == "darwin" ]]; then
  _matches=0 _drifted=0 _missing=0
  while IFS= read -r _audit_line; do
    IFS='|' read -r _result _domain _key _expected _actual <<< "${_audit_line}|||"
    case "$_result" in
      match)
        _matches=$((_matches + 1))
        ;;
      drift)
        printf '\033[0;33m  \xe2\x86\x92 macos: %s.%s = %s (expected %s)\033[0m\n' \
          "$_domain" "$_key" "$_actual" "$_expected"
        _drifted=$((_drifted + 1))
        _WARNS=$((_WARNS + 1))
        ;;
      missing)
        # shellcheck disable=SC2016  # backticks are literal text in the message
        printf '\033[0;33m  \xe2\x86\x92 macos: %s.%s unset (run `dot sync --only=macos`)\033[0m\n' \
          "$_domain" "$_key"
        _missing=$((_missing + 1))
        _WARNS=$((_WARNS + 1))
        ;;
    esac
  done < <(macos_audit)
  _ok "macos defaults: ${_matches} matched, ${_drifted} drifted, ${_missing} missing"
  unset _matches _drifted _missing _audit_line _result _domain _key _expected _actual
fi

# ── 10. SSH signing chain ────────────────────────────────────────────────────
printf '\n==> SSH signing\n'

_op_sock="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
if [[ -S "$_op_sock" ]]; then
  _ok "1Password agent socket present (auth + signing)"
else
  _warn "1Password agent socket missing — enable Settings -> Developer -> SSH agent"
fi
unset _op_sock

_op_sign="/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
if [[ -x "$_op_sign" ]]; then
  _ok "op-ssh-sign present"
else
  _warn "op-ssh-sign not found — install 1Password"
fi
if [[ "$(git config gpg.ssh.program 2> /dev/null || true)" == "$_op_sign" ]]; then
  _ok "gpg.ssh.program -> op-ssh-sign"
else
  _warn "gpg.ssh.program not set to op-ssh-sign — run: dot sync --only=ssh"
fi
unset _op_sign

_eff_key=$(git config user.signingkey 2> /dev/null || true)
if [[ "$_eff_key" == key::* ]]; then
  _ok "user.signingkey set (1Password key)"
  if grep -qF "${_eff_key#key::}" "${HOME}/.ssh/allowed_signers" 2> /dev/null; then
    _ok "signing key present in allowed_signers"
  else
    _warn "signing key missing from ~/.ssh/allowed_signers — run: dot sync --only=ssh"
  fi
else
  _warn "user.signingkey not set — run: dot sync --only=ssh (with 1Password unlocked)"
fi
unset _eff_key

# ── 11. SSH ControlPath socket dir (must be user-private) ────────────────────
# ssh/config keeps multiplexing sockets under ~/.ssh/cm (not world-writable
# /tmp). If the dir exists it must be 700, or another local user could race it.
_cmdir="${HOME}/.ssh/cm"
if [[ -d "$_cmdir" ]]; then
  _perms=$(stat -f '%Lp' "$_cmdir" 2> /dev/null || true)
  if [[ "$_perms" == "700" ]]; then
    _ok "ssh ControlPath dir ~/.ssh/cm is 700"
  else
    _warn "ssh ControlPath dir ~/.ssh/cm is ${_perms:-unknown}, expected 700 — run: chmod 700 ~/.ssh/cm"
  fi
  unset _perms
fi
unset _cmdir

# ── 12. On-disk SSH private keys (1Password Watchtower parity) ───────────────
# 1Password's guidance: SSH keys live IN 1Password (touch-to-sign via the agent),
# not as plaintext files scattered in ~/.ssh. Flag any private key on disk so it
# can be imported into 1Password and the local copy removed. Read-only — only
# reads each file's first line to spot a private-key header.
_ssh_dir="${HOME}/.ssh"
if [[ -d "$_ssh_dir" ]]; then
  _ondisk_keys=0
  while IFS= read -r -d '' _kf; do
    if head -1 "$_kf" 2> /dev/null | grep -q 'PRIVATE KEY-----'; then
      _warn "on-disk SSH private key: ${_kf} — import into 1Password and remove (keys belong in the agent, not on disk)"
      _ondisk_keys=$((_ondisk_keys + 1))
    fi
  done < <(find "$_ssh_dir" -maxdepth 1 -type f ! -name '*.pub' -print0 2> /dev/null)
  [[ "$_ondisk_keys" -eq 0 ]] && _ok "no on-disk SSH private keys (keys live in 1Password)"
  unset _ondisk_keys _kf
fi
unset _ssh_dir

# ── Summary ───────────────────────────────────────────────────────────────────
printf '\n'
[[ "$_FIXED" -gt 0 ]] && printf '\033[0;36m  \xe2\x9c\x82 repaired %d symlink issue(s)\033[0m\n' "$_FIXED"
if [[ "$_FAILS" -eq 0 && "$_WARNS" -eq 0 ]]; then
  _ok "All checks passed"
  exit 0
elif [[ "$_FAILS" -eq 0 ]]; then
  # Warnings only — degraded but not broken. Exit 2 so "clean" is distinct from
  # "drifted" for any caller that checks the status (CI, bootstrap, cron).
  _p_warn "$_WARNS warning(s) — see above (degraded, not broken)"
  exit 2
else
  _p_fail "$_FAILS error(s), $_WARNS warning(s)"
  exit 1
fi
