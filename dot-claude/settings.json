{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "EDITOR": "nvim",
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:simonwillison.net)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:objects.githubusercontent.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.bun.sh)",
      "WebFetch(domain:astro.build)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:stackoverflow.com)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git stash list)",
      "Bash(git worktree list)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",

      "Bash(git add*)",
      "Bash(git commit -m*)",
      "Bash(git commit -F*)",
      "Bash(git stash)",
      "Bash(git stash push*)",
      "Bash(git stash pop)",
      "Bash(git checkout -b*)",
      "Bash(git switch*)",
      "Bash(git fetch*)",
      "Bash(git pull)",
      "Bash(git push)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push origin*)",
      "Bash(git push -u*)",
      "Bash(git worktree add*)",
      "Bash(git worktree remove*)",
      "Bash(git tag*)",
      "Bash(git mv*)",
      "Bash(git rm*)",

      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(wc*)",
      "Bash(which*)",
      "Bash(file*)",
      "Bash(du*)",
      "Bash(df*)",
      "Bash(readlink*)",
      "Bash(realpath*)",
      "Bash(tree*)",
      "Bash(stat*)",
      "Bash(basename*)",
      "Bash(dirname*)",
      "Bash(env)",
      "Bash(echo*)",
      "Bash(printf*)",
      "Bash(date)",
      "Bash(date +*)",
      "Bash(id)",
      "Bash(uname*)",
      "Bash(whoami)",
      "Bash(hostname)",

      "Bash(bun pm ls*)",
      "Bash(bun outdated)",
      "Bash(bun info*)",
      "Bash(npm ls*)",
      "Bash(npm outdated)",
      "Bash(npm view*)",
      "Bash(pnpm ls*)",
      "Bash(pnpm outdated)",
      "Bash(yarn info*)",
      "Bash(mise ls*)",
      "Bash(mise current*)",
      "Bash(mise which*)",
      "Bash(mise env*)",
      "Bash(brew list*)",
      "Bash(brew info*)",
      "Bash(brew outdated)",
      "Bash(brew doctor)",

      "Bash(gh auth status)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh repo view*)",
      "Bash(gh api*)",

      "Bash(bun run*)",
      "Bash(bun test*)",
      "Bash(bun x*)",
      "Bash(bunx*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(pnpm run*)",
      "Bash(pnpm test*)",
      "Bash(pnpm exec*)",
      "Bash(pnpx*)",
      "Bash(yarn run*)",
      "Bash(yarn test*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo clippy*)",
      "Bash(cargo fmt*)",
      "Bash(cargo build*)",
      "Bash(cargo run*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(go build*)",
      "Bash(go run*)",
      "Bash(node ace test*)",

      "Skill(commit-commands:commit)",
      "Skill(commit-commands:commit-push-pr)",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f)",
      "Bash(git clean -f *)",
      "Bash(git clean -d)",
      "Bash(git clean -d *)",
      "Bash(git clean -fd*)",
      "Bash(git clean -df*)",
      "Bash(git rebase -i*)",
      "Bash(git commit --amend*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",

      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",

      "Bash(sudo)",
      "Bash(sudo *)",

      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",

      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(cargo publish*)",

      "Bash(gh repo delete*)",
      "Bash(gh pr merge*)",
      "Bash(gh release delete*)",

      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker image prune*)",
      "Bash(brew uninstall*)",

      "Bash(dropdb*)",
      "Bash(createdb --force*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lock-file-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/format-on-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cwd-changed.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/jarvis/.claude/statusline-command.sh",
    "padding": 0,
    "refreshInterval": 30000
  },
  "enabledPlugins": {
    "expo@expo-plugins": false,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "supabase@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "playground@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "scram@jrvs-skills": false,
    "playwright@claude-plugins-official": false,
    "implement@gnar": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "spacebase@gnar": true,
    "cloudflare@gnar": true
  },
  "extraKnownMarketplaces": {
    "expo-plugins": {
      "source": {
        "source": "github",
        "repo": "expo/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "jrvs-skills": {
      "source": {
        "source": "github",
        "repo": "alxjrvs/skills-lib"
      }
    },
    "gnar": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills"
      },
      "autoUpdate": true
    }
  },
  "outputStyle": "Concise",
  "sandbox": {
    "enabled": true
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "teammateMode": "separate-process",
  "mcpServers": {
    "knip": {
      "command": "npx",
      "args": [
        "-y",
        "@knip/mcp"
      ]
    }
  }
}
