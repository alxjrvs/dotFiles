{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "env": {
    "EDITOR": "hx",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "META_TELEMETRY_ENABLE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "WebSearch",
      "Bash(cargo *)",
      "Bash(lefthook *)",
      "Skill(superpowers:*)",
      "Skill(implement:*)",
      "Skill(frontend-design:*)",
      "mcp__plugin_context7_context7__*",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(mise *)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git rebase -i*)",
      "Bash(git commit --amend*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(cargo publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Bash(gh ssh-key add*)",
      "Bash(gh gpg-key add*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git config*)",
      "Bash(git restore*)",
      "Bash(git push --delete*)",
      "Bash(git push origin :*)",
      "Bash(gh secret set*)",
      "Bash(gh variable set*)",
      "Bash(gh repo edit*)",
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker image prune*)",
      "Bash(dropdb*)",
      "Bash(createdb --force*)",
      "Bash(gh pr merge*)",
      "Bash(open *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp/claude",
      "/private/tmp/claude"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook lock-file-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook policy-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook format-on-save",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook trim-bash-output",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook user-prompt-submit",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook cwd-changed",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook pre-compact",
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook permission-denied",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook subagent-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook worktree-create",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dotctl hook worktree-remove",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules"
    ],
    "baseRef": "head",
    "bgIsolation": "worktree"
  },
  "statusLine": {
    "type": "command",
    "command": "dotctl statusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "spacebase@gnar-next": true,
    "superpowers@claude-plugins-official": true,
    "ideate@gnar-next": true,
    "audit@gnar-next": true,
    "ignite@gnar-next": true,
    "implement@gnar-next": true,
    "meta@gnar-next": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "gnar-next": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills",
        "ref": "next"
      },
      "autoUpdate": true
    }
  },
  "forceLoginMethod": "claudeai",
  "outputStyle": "Concise",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com",
        "*.claude.com",
        "*.npmjs.org",
        "*.jsr.io",
        "*.brew.sh",
        "developer.mozilla.org",
        "bun.sh",
        "nodejs.org",
        "typescriptlang.org",
        "stackoverflow.com"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.SecurityServer",
        "com.apple.securityd.systemkeychain",
        "com.apple.security.KeychainStasher",
        "com.apple.security.XPCKeychainSandboxCheck",
        "com.apple.trustd.agent",
        "com.apple.pboard",
        "com.apple.pasteboard.*"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.claude",
        "~/.claude.json",
        "~/.config/.wrangler",
        "~/.config/gh",
        "/dev/ptmx",
        "/dev/ttys",
        "~/**/.git/**",
        "~/**/.git/config",
        "~/**/.git/config.lock",
        "~/.gitconfig",
        "~/.npm",
        "~/.bun/install/cache",
        "~/.cargo/**",
        "~/.local/share/mise/**",
        "~/.local/share/cc-worktrees/**",
        "~/.cache",
        "/tmp/claude",
        "/private/tmp/claude",
        "/opt/homebrew",
        "~/Library/Caches/Homebrew",
        "~/Library/Logs/Homebrew",
        "~/**/.git/HEAD",
        "~/**/.git/index",
        "~/**/.git/index.lock",
        "~/**/.git/objects/**",
        "~/**/.git/refs/**",
        "~/**/.git/logs/**",
        "~/**/.git/worktrees/**"
      ],
      "denyRead": [
        "~/.aws",
        "~/.gnupg",
        "~/.netrc",
        "~/.config/op"
      ]
    },
    "excludedCommands": [
      "git",
      "gh",
      "lefthook",
      "cargo",
      "brew",
      "open",
      "node",
      "bun",
      "bunx",
      "mise",
      "sh",
      "bash",
      "gitleaks"
    ]
  },
  "feedbackSurveyRate": 0,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vi",
  "verbose": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "isolatePeerMachines": true,
  "daemonColdStart": "ask",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
