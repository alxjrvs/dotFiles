{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingMaxDescChars": 400,
  "skillListingBudgetFraction": 0.005,
  "env": {
    "EDITOR": "nvim",
    "NODE_ENV": "development",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(sed:*)",
      "WebSearch",
      "Bash(cargo *)",
      "Bash(lefthook *)",
      "Skill(commit-commands:*)",
      "Skill(superpowers:*)",
      "Skill(implement:*)",
      "Skill(pr-review-toolkit:*)",
      "Skill(hookify:*)",
      "Skill(frontend-design:*)",
      "Skill(update-config)",
      "mcp__plugin_context7_context7",
      "mcp__gnar-term",
      "mcp__code-review-graph",
      "Bash(npx svelte-check *)",
      "Bash(npx prettier --check *)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git rebase -i*)",
      "Bash(git commit --amend*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(cargo publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Bash(gh ssh-key add*)",
      "Bash(gh gpg-key add*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git config*)",
      "Bash(git restore*)",
      "Bash(git push --delete*)",
      "Bash(git push origin :*)",
      "Bash(gh secret set*)",
      "Bash(gh variable set*)",
      "Bash(gh repo edit*)",
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker image prune*)",
      "Bash(dropdb*)",
      "Bash(createdb --force*)",
      "Bash(gh pr merge*)",
      "Bash(open *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp/claude",
      "/private/tmp/claude"
    ]
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "skillOverrides": {
    "commit-commands:commit": "user-invocable-only",
    "commit-commands:commit-push-pr": "user-invocable-only",
    "commit-commands:clean_gone": "user-invocable-only",
    "review": "user-invocable-only",
    "security-review": "user-invocable-only",
    "init": "user-invocable-only"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lock-file-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/format-on-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/user-prompt-submit.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cwd-changed.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/jarvis/.claude/statusline-command.sh",
    "padding": 0,
    "refreshInterval": 30000
  },
  "enabledPlugins": {
    "expo@expo-plugins": false,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "vercel@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "scram@jrvs-skills": false,
    "playwright@claude-plugins-official": false,
    "implement@gnar": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "spacebase@gnar": false,
    "cloudflare@gnar": false
  },
  "extraKnownMarketplaces": {
    "expo-plugins": {
      "source": {
        "source": "github",
        "repo": "expo/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "jrvs-skills": {
      "source": {
        "source": "github",
        "repo": "alxjrvs/skills-lib"
      }
    },
    "gnar": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills"
      },
      "autoUpdate": true
    }
  },
  "outputStyle": "Concise",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com",
        "*.claude.com",
        "*.npmjs.org",
        "registry.npmjs.org",
        "*.jsr.io",
        "*.brew.sh",
        "developer.mozilla.org",
        "bun.sh",
        "nodejs.org",
        "typescriptlang.org",
        "stackoverflow.com"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.SecurityServer",
        "com.apple.securityd.systemkeychain",
        "com.apple.security.KeychainStasher",
        "com.apple.security.XPCKeychainSandboxCheck",
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.claude",
        "~/.claude.json",
        "~/.config/.wrangler",
        "~/.config/gh",
        "/dev/ptmx",
        "/dev/ttys",
        ".git",
        "~/.gitconfig",
        "~/.npm",
        "~/.bun/install/cache",
        "~/.cache",
        "/tmp",
        "/private/tmp",
        "/opt/homebrew",
        "~/Library/Caches/Homebrew",
        "~/Library/Logs/Homebrew"
      ],
      "denyRead": [
        "~/.aws",
        "~/.gnupg",
        "~/.netrc",
        "~/.config/op"
      ]
    },
    "excludedCommands": [
      "git",
      "gh",
      "lefthook",
      "cargo",
      "brew",
      "open"
    ]
  },
  "feedbackSurveyRate": 0,
  "autoCompactWindow": 600000,
  "advisorModel": "opus",
  "autoUpdatesChannel": "latest",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim",
  "verbose": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
