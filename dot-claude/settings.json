{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "GIT_AUTHOR_NAME": "Claude",
    "GIT_AUTHOR_EMAIL": "alxjrvs+claude@gmail.com",
    "GIT_COMMITTER_NAME": "Claude",
    "GIT_COMMITTER_EMAIL": "alxjrvs+claude@gmail.com",
    "GIT_CONFIG_COUNT": "4",
    "GIT_CONFIG_KEY_0": "commit.gpgsign",
    "GIT_CONFIG_VALUE_0": "false",
    "GIT_CONFIG_KEY_1": "tag.gpgsign",
    "GIT_CONFIG_VALUE_1": "false",
    "GIT_CONFIG_KEY_2": "credential.https://github.com.helper",
    "GIT_CONFIG_VALUE_2": "",
    "GIT_CONFIG_KEY_3": "credential.https://github.com.helper",
    "GIT_CONFIG_VALUE_3": "osxkeychain",
    "SPACEBASE_API_KEY_COMMAND": "OP_SERVICE_ACCOUNT_TOKEN=\"$(security find-generic-password -s op-claude-agent -w)\" /opt/homebrew/bin/op read 'op://claude-agent/Spacebase API Key/credential'",
    "SPACEBASE_API_KEY": "",
    "SPACEBASE_URL": "",
    "SPACEBASE_PROJECT_ID": ""
  },
  "attribution": {
    "commit": "Co-Authored-By: alxjrvs <alxjrvs@gmail.com>"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/claude-statusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "~/.local/bin/claude-subagent-statusline"
  },
  "enabledPlugins": {
    "audit@gnar": true,
    "ideate@gnar": true,
    "ignite@gnar": true,
    "spacebase@gnar": true,
    "toolkit@gnar": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "gnar": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills"
      },
      "autoUpdate": true
    }
  },
  "skipWorkflowUsageWarning": true,
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false,
  "teammateMode": "in-process",
  "inputNeededNotifEnabled": true
}
