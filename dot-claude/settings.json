{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "EDITOR": "nvim",
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(bun run *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(gh api:*)",
      "WebSearch",
      "WebFetch(domain:axios-http.com)",
      "WebFetch(domain:tkdodo.eu)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:altrim.io)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:ppbruna.medium.com)",
      "WebFetch(domain:www.neldeles.com)",
      "WebFetch(domain:bobbyhadz.com)",
      "WebFetch(domain:www.kxlaa.com)",
      "WebFetch(domain:blog.revathskumar.com)",
      "WebFetch(domain:apidog.com)",
      "Bash(npx skills-ref:*)",
      "Bash(npm run:*)",
      "WebFetch(domain:react-hook-form.com)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:www.contentful.com)",
      "WebFetch(domain:wasp.sh)",
      "Bash(source:*)",
      "Bash(for skill in ideate-breakdown/ideate-*/; do echo \"=== $skill ===\" && npx skills-ref validate \"./$skill\" 2>&1; done)",
      "Bash(for skill in ideate/ideate ideate/ideate-research ideate/ideate-breakdown ideate/ideate-competitors ideate/ideate-tribal-knowledge ideate/ideate-opportunity ideate/ideate-moscow ideate/ideate-prd ideate/ideate-requirements ideate/ideate-milestones ideate/ideate-architecture ideate/ideate-staffing ideate/ideate-prototype ideate/ideate-summary; do echo -n \"$skill: \" && npx skills-ref validate ./$skill 2>&1; done)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(find:*)",
      "Bash(cd:*)",
      "Bash(/Users/jarvis/Code/Gnar/skills-library/scripts/link-skills.sh:*)",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_close",
      "WebFetch(domain:www.thegnar.com)",
      "WebFetch(domain:cdn.prod.website-files.com)",
      "mcp__plugin_playwright_playwright__browser_navigate"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '(Brewfile\\.lock|bun\\.lock|package-lock|yarn\\.lock|pnpm-lock|Gemfile\\.lock|Cargo\\.lock|composer\\.lock)'; then echo 'BLOCK: Do not edit lock files directly' >&2; exit 2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$TOOL_INPUT\" | jq -r '.file_path // empty') && [[ \"$FILE\" == *.sh ]] && command -v shfmt &>/dev/null && shfmt -w -i 2 \"$FILE\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "elements-of-style@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "double-shot-latte@superpowers-marketplace": true,
    "hookify@claude-plugins-official": true,
    "upgrading-expo@expo-plugins": true,
    "expo-app-design@expo-plugins": true,
    "context7@claude-plugins-official": true,
    "claude-session-driver@superpowers-marketplace": true
  },
  "outputStyle": "Concise",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable"
}
