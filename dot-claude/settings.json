      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:stackoverflow.com)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git branch -a*)",
      "Bash(git branch -v*)",
      "Bash(git branch -vv*)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git remote get-url*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git stash list)",
      "Bash(git stash show*)",
      "Bash(git reflog)",
      "Bash(git reflog show*)",
      "Bash(git shortlog*)",
      "Bash(git merge-base*)",
      "Bash(git name-rev*)",
      "Bash(git for-each-ref*)",
      "Bash(git count-objects*)",
      "Bash(git grep*)",
      "Bash(git add*)",
      "Bash(git commit -m*)",
      "Bash(git commit -F*)",
      "Bash(git stash)",
      "Bash(git stash push*)",
      "Bash(git stash pop)",
      "Bash(git checkout -b*)",
      "Bash(git switch*)",
      "Bash(git fetch*)",
      "Bash(git pull)",
      "Bash(git push*)",
      "Bash(git worktree*)",
      "Bash(git tag*)",
      "Bash(git mv*)",
      "Bash(git rm*)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(tree*)",
      "Bash(wc*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(which*)",
      "Bash(type *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(whoami)",
      "Bash(date*)",
      "Bash(realpath*)",
      "Bash(readlink*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(cat*)",
      "Bash(diff*)",
      "Bash(echo*)",
      "Bash(printf*)",
      "Bash(node --version)",
      "Bash(bun --version)",
      "Bash(npm --version)",
      "Bash(brew --version)",
      "Bash(git --version)",
      "Bash(mise --version)",
      "Bash(rg --version)",
      "Bash(fzf --version)",
      "Bash(bun pm ls*)",
      "Bash(bun outdated)",
      "Bash(bun info*)",
      "Bash(bun run*)",
      "Bash(bun test*)",
      "Bash(bun x*)",
      "Bash(bunx*)",
      "Bash(npm ls*)",
      "Bash(npm outdated)",
      "Bash(npm view*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(mise ls*)",
      "Bash(mise current*)",
      "Bash(mise which*)",
      "Bash(mise env*)",
      "Bash(brew list*)",
      "Bash(brew info*)",
      "Bash(brew outdated*)",
      "Bash(brew deps*)",
      "Bash(brew leaves)",
      "Bash(brew search*)",
      "Bash(gh auth status)",
      "Bash(gh repo view*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gh browse*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(gh api*)",
      "Bash(gh pr create*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue create*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh run watch*)",
      "Bash(gh search*)",
      "Bash(defaults read *)",
      "Skill(commit-commands:commit)",
      "Skill(commit-commands:commit-push-pr)",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "ask": [
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(rm *)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f)",
      "Bash(git clean -f *)",
      "Bash(git clean -d)",
      "Bash(git clean -d *)",
      "Bash(git clean -fd*)",
      "Bash(git clean -df*)",
      "Bash(git rebase -i*)",
      "Bash(git commit --amend*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog delete*)",
      "Bash(git reflog expire*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(npm publish*)",
      "Bash(bun publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(cargo publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh pr merge*)",
      "Bash(gh release delete*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker image prune*)",
      "Bash(brew uninstall*)",
      "Bash(dropdb*)",
      "Bash(createdb --force*)"
    ],
    "additionalDirectories": [
      "/tmp/claude",
      "/private/tmp/claude"
    ],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lock-file-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/format-on-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/user-prompt-submit.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cwd-changed.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/jarvis/.claude/statusline-command.sh",
    "padding": 0,
    "refreshInterval": 30000
  },
  "enabledPlugins": {
    "expo@expo-plugins": false,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "vercel@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "scram@jrvs-skills": false,
    "playwright@claude-plugins-official": false,
    "implement@gnar": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "spacebase@gnar": false,
    "cloudflare@gnar": false
  },
  "extraKnownMarketplaces": {
    "expo-plugins": {
      "source": {
        "source": "github",
        "repo": "expo/skills"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "jrvs-skills": {
      "source": {
        "source": "github",
        "repo": "alxjrvs/skills-lib"
      }
    },
    "gnar": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills"
      },
      "autoUpdate": true
    }
  },
  "outputStyle": "Concise",
  "sandbox": {
    "enabled": true
  },
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true
}
