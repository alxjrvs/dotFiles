{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "editorMode": "vim",
  "env": {
    "EDITOR": "nvim",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "worktree": {
    "baseRef": "fresh",
    "symlinkDirectories": [
      "node_modules"
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp/claude",
      "/private/tmp/claude"
    ],
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(dot *)",
      "WebSearch",
      "Skill(superpowers:*)",
      "Skill(implement:*)"
    ],
    "ask": [
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean)",
      "Bash(git clean *)",
      "Bash(git commit --amend*)",
      "Bash(git branch -D*)",
      "Bash(git push --delete*)",
      "Bash(git push origin :*)",
      "Bash(git restore*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(gh api *)",
      "Bash(gh secret set*)",
      "Bash(gh variable set*)",
      "Bash(gh repo edit*)",
      "Bash(gh release delete*)",
      "Bash(npm publish*)",
      "Bash(bun publish*)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git *--no-verify*)",
      "Bash(git *--no-gpg-sign*)",
      "Bash(git -c *)",
      "Bash(git rebase -i*)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(cargo publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh gist *)",
      "Bash(gh alias set*)",
      "Bash(gh ssh-key add*)",
      "Bash(gh gpg-key add*)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.config/op/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.ssh/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.terraform.d/**)",
      "Read(~/.git-credentials)",
      "Read(~/.config/git/credentials)",
      "Read(~/.cargo/credentials.toml)",
      "Read(~/Library/Keychains/**)",
      "Read(~/Library/Cookies/**)",
      "Read(~/Library/Application Support/**/Cookies*)",
      "Read(~/Library/Group Containers/2BUA8C4S2C.com.1password/**)",
      "Read(**/.envrc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(~/.claude/.credentials.json)",
      "Edit(~/.gitconfig)",
      "Edit(~/.config/git/config)",
      "Edit(~/**/.git/config)",
      "Edit(~/**/.git/hooks/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.claude.json)",
      "Edit(~/.cargo/credentials.toml)",
      "Edit(~/.cargo/config.toml)",
      "Edit(//opt/homebrew/bin/**)",
      "Edit(//opt/homebrew/sbin/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "git",
      "gh",
      "brew",
      "open",
      "dot",
      "pbcopy"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com",
        "*.claude.com",
        "*.npmjs.org",
        "*.jsr.io",
        "nodejs.org",
        "bun.sh",
        "static.rust-lang.org",
        "crates.io",
        "index.crates.io",
        "static.crates.io",
        "*.brew.sh",
        "localhost",
        "127.0.0.1"
      ],
      "allowLocalBinding": true,
      "allowUnixSockets": [
        "~/.ssh/agent/signing.sock"
      ],
      "allowMachLookup": [
        "com.apple.SecurityServer",
        "com.apple.securityd.systemkeychain",
        "com.apple.security.KeychainStasher",
        "com.apple.security.XPCKeychainSandboxCheck",
        "com.apple.trustd.agent"
      ]
    },
    "filesystem": {
      "allowRead": [
        "~/.ssh/*.pub",
        "~/.ssh/config",
        "~/.ssh/known_hosts*",
        "~/.ssh/agent",
        "~/Library/Keychains/login.keychain-db",
        "**/.env.example",
        "**/.env.template",
        "**/.env.sample"
      ],
      "denyRead": [
        "~/.aws",
        "~/.gnupg",
        "~/.netrc",
        "~/.config/op",
        "~/.kube",
        "~/.npmrc",
        "~/.claude/.credentials.json",
        "~/.ssh",
        "~/.docker/config.json",
        "~/.config/gcloud",
        "~/.terraform.d",
        "~/.git-credentials",
        "~/.config/git/credentials",
        "~/.cargo/credentials.toml",
        "~/Library/Keychains",
        "~/Library/Cookies",
        "~/Library/Application Support/**/Cookies*",
        "~/Library/Group Containers/2BUA8C4S2C.com.1password",
        "**/.envrc",
        "**/.env",
        "**/.env.*"
      ],
      "allowWrite": [
        "~/.claude",
        "~/.cache",
        "~/.npm",
        "~/.bun/install/cache",
        "~/.cargo",
        "~/.local/share/mise",
        "~/Library/Caches/mise",
        "/opt/homebrew",
        "~/Library/Caches/Homebrew",
        "~/Library/Logs/Homebrew",
        "~/**/node_modules",
        "~/**/.git",
        "/tmp/claude",
        "/private/tmp/claude",
        "/dev/ptmx",
        "/dev/ttys"
      ],
      "denyWrite": [
        "~/.claude/.credentials.json",
        "~/.claude.json",
        "~/.gitconfig",
        "~/.config/git/config",
        "~/.ssh",
        "~/.cargo/credentials.toml",
        "~/.cargo/config.toml",
        "/opt/homebrew/bin",
        "/opt/homebrew/sbin"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook lock-file-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook mcp-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook format-on-save",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook trim-bash-output",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook precompact",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook subagent-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook user-prompt-submit",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "dot hook stop",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "dot statusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "dot subagent-statusline"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "implement@gnar-next": true,
    "meta@gnar-next": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "gnar-next": {
      "source": {
        "source": "github",
        "repo": "thegnarco/agent-skills",
        "ref": "next"
      },
      "autoUpdate": false
    }
  }
}
