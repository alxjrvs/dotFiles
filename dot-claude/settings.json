{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "EDITOR": "nvim",
    "NODE_ENV": "development",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(xxd:*)",
      "Bash(head:*)",
      "Bash(chezmoi update:*)",
      "Bash(bash:*)",
      "Bash(git add:*)",
      "Bash(zsh:*)",
      "Bash(git push:*)",
      "Bash(asdf set:*)",
      "Bash(asdf list:*)",
      "Bash(./install.sh:*)",
      "Bash(printf:*)",
      "Bash(brew doctor:*)",
      "Bash(brew list:*)",
      "Bash(brew deps:*)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "WebFetch(domain:simonwillison.net)",
      "Bash(python3:*)",
      "Skill(commit-commands:commit-push-pr)",
      "Bash(tmux source-file:*)",
      "Bash(tmux set:*)",
      "Bash(tmux list-hooks:*)",
      "Bash(hexdump:*)",
      "Bash(git:*)",
      "WebFetch(domain:mise.jdx.dev)",
      "Bash(tmux set-hook:*)",
      "Bash(tmux list-keys:*)",
      "Bash(starship prompt:*)",
      "Bash(starship config:*)",
      "Bash(starship print-config:*)",
      "Skill(commit-commands:commit)",
      "Bash(which mise:*)",
      "Bash(echo:*)",
      "Bash(tmux set-window-option:*)",
      "Bash(.:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '(Brewfile\\.lock|bun\\.lock|package-lock|yarn\\.lock|pnpm-lock|Gemfile\\.lock|Cargo\\.lock|composer\\.lock)'; then echo 'BLOCK: Do not edit lock files directly' >&2; exit 2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$TOOL_INPUT\" | jq -r '.file_path // empty') && [[ \"$FILE\" == *.sh ]] && command -v shfmt &>/dev/null && shfmt -w -i 2 \"$FILE\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/jarvis/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "elements-of-style@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "double-shot-latte@superpowers-marketplace": true,
    "upgrading-expo@expo-plugins": true,
    "expo-app-design@expo-plugins": true,
    "claude-session-driver@superpowers-marketplace": true,
    "expo-deployment@expo-plugins": true,
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true
  },
  "outputStyle": "Concise",
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "mcpServers": {
    "knip": {
      "command": "npx",
      "args": [
        "-y",
        "@knip/mcp"
      ]
    }
  }
}
